# Godot-specific ignores
.agents/
target/

# Downloaded mission data
.cache/
extern/

# Web bundle output (final shippable wasm + JS + HTML)
dist/

# Locally installed cargo binaries (e.g. wasm-bindgen-cli) used by build scripts.
# Kept outside target/ so `cargo clean` doesn't force a reinstall.
.cargo-bin/

# AI tool configs
external/

# IDE/Editor
.idea/
.vscode/
*.swp
*.swo
.claude/settings.local.json
node_modules/

.cargo/

# graphify generated outputs
graphify-out/