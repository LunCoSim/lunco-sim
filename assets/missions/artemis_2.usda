#usda 1.0
(
    defaultPrim = "Artemis2"
    upAxis = "Y"
    metersPerUnit = 1
)

def Xform "Artemis2" (
    prepend apiSchemas = ["LunCoCatalogAPI"]
    kind = "assembly"
)
{
    uniform bool lunco:spawnable = false

    def Xform "Orion" (
        prepend references = @../vessels/spacecrafts/orion/orion.usda@
    )
    {
        custom string lunco:name = "Artemis 2 Orion"
        double3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
