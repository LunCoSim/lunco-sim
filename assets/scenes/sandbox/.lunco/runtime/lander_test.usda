#usda 1.0

over "LanderTest"
{
    def Scope "Behaviors"
    {
    }
    over "SkidRover"
    {
        def LunCoProgram "Mission"
        {
            custom string info:sourceCode = """<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Repeat num_cycles="-1">
      <Sequence>
        <Action ID="drive_to" target="19.956288;0.000000;-23.065046"/>
        <Action ID="drive_to" target="-1.912182;4.512839;-0.059345"/>
        <Action ID="drive_to" target="1.868318;0.289880;-12.614985"/>
        <Action ID="drive_to" target="0.655433;4.031335;2.526146"/>
        <Action ID="drive_to" target="8.937906;0.000000;-4.072163"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>
</root>"""
        }
    }
}
