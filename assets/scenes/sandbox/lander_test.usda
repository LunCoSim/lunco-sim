#usda 1.0
(
    defaultPrim = "LanderTest"
    upAxis = "Y"
    metersPerUnit = 1
)

# Self-contained powered-descent lander cosim scene.
#
# The chain is entirely the unified cosim wiring fabric — no bespoke Rust:
#
#   Avian body  ──(out height)──────► Lander.mo  altitude
#               ──(out velocity_y)──► Lander.mo  descent_rate
#                                         │  PID hover/descent law
#                                         ▼  output `thrust`
#   self-wire  thrust ─────► force_local_y  (BODY-FRAME thrust port, gap G1)
#
# Gravity is applied by lunco-environment (sandbox default 9.81 NEG_Y); the
# model must NOT re-apply it. Body-frame thrust means the engine fires along
# the lander's own +Y, so it follows attitude (validates the new force_local_*
# ports without needing a separate gimbal demo yet).
#
# Controls:
#   Space       — full thrust
#   W/S/A/D     — pitch/roll torque
#   Q/E         — yaw torque
#   G           — detach rover joint
#   P           — pause/unpause simulation
#   Backspace   — release possession
#
#   sandbox --scene scenes/sandbox/lander_test.usda

def Xform "LanderTest"
{
    custom bool lunco:spawnable = false
    custom string lunco:description = "A lander dropping under gravity with a rocket you can fire to slow and steer it. Hold Space to thrust, WASD to tilt, Q/E to turn, G to release the rover, P to pause."

    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f primvars:displayColor = (0.35, 0.33, 0.38)
        bool physics:collisionEnabled = true
        float physics:friction = 1.0
    }

    def Xform "Avatar"
    {
        string lunco:avatar = "true"
        string lunco:cameraMode = "freeflight"
        custom double3 lunco:cameraLookAt = (0.0, 30.0, 0.0)
        double3 xformOp:translate = (18.0, 12.0, 20.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DistantLight "Sun"
    {
        float inputs:intensity = 12000
        float inputs:angle = 0.53
        double3 xformOp:rotateXYZ = (-30.0, 45.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    # ── The powered-descent lander ──────────────────────────────────────────
    # Main body: cylindrical tank with structural details. Starts at 30 m,
    # auto-descends via the rhai script, then hands control to the user.
    def Cylinder "Lander" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsCollisionAPI", "PhysicsMassAPI"]
    )
    {
        uniform token axis = "Y"
        double radius = 2.5
        double height = 3.0
        double3 xformOp:translate = (0, 60.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f primvars:displayColor = (0.85, 0.83, 0.78)

        string primvars:materialType = "shader"
        string primvars:shaderPath = "shaders/solar_panel.wgsl"
        float primvars:seamless_u = 1.0
        float primvars:v_scale = 8.0
        float primvars:cell_rows = 20.0
        float primvars:cell_cols = 6.0
        float primvars:cell_gap = 0.006
        float primvars:bus_width = 0.002
        float primvars:border = 0.04
        color3f primvars:cell_color = (0.03, 0.03, 0.25)
        color3f primvars:bus_color = (0.95, 0.95, 0.98)
        color3f primvars:frame_color = (0.1, 0.1, 0.12)

        bool physics:rigidBodyEnabled = true
        bool physics:collisionEnabled = true
        float physics:mass = 2000.0
        float physics:linearDamping = 0.02
        double3 physics:linearVelocity = (-5.0, 0.0, -5.0)

        string lunco:vessel = "true"

        # Cosim: bind the lander GNC (Lander.mo) and self-wire its I/O.
        #   thrust        --> force_local_y  (actuate, body-frame)
        #   height        --> altitude       (PID measurement)
        #   velocity_y    --> descent_rate   (PID damping term)
        #   gravity_accel --> g              (env-correct gravity feed-forward; lunar ≈ 1.62)
        string lunco:modelicaModel = "models/Lander.mo"
        string lunco:simWires = "force_x:force_x,force_y:force_y,force_z:force_z,torque_x:torque_x,torque_y:torque_y,torque_z:torque_z,position_x:pos_x,position_y:pos_y,position_z:pos_z,velocity_x:vel_x,velocity_y:vel_y,velocity_z:vel_z,quat_w:q_w,quat_x:q_x,quat_y:q_y,quat_z:q_z,angvel_x:w_x,angvel_y:w_y,angvel_z:w_z,gravity_accel:g,throttle:throttle"

        # Modelica `when` events: threshold crossings of the model's continuous
        # OUTPUT signals become discrete events on the bus (edge detection in Rust,
        # rumoca-safe). The lander script (and any other) reacts via on_event.
        custom string lunco:portEvents = "m_prop<200:lander_low_fuel, m_prop<=0.5:lander_depleted"

        # The MISSION orchestration lives on the `/LanderTest/Scenario` prim below.
        # This entity carries the lander's GNC Modelica model (above) AND a local
        # supervisory script (below) at the same time — one entity, a model + a
        # script (doc 34, Decision 1). The script monitors the GNC's propellant
        # port and disarms a dry engine; it does NOT fly the descent.
        custom string lunco:scriptPath = "scenarios/lander_subsystems.rhai"
        custom string lunco:params = "speed=5.0, angular_speed=2.0"

        # ── Physics hull ──
        # Enabling colliders on the footpads switches this rigid body into
        # CHILDREN-ONLY compound mode (lunco-usd-avian: a parent with any
        # collider-child drops its own shape). This invisible child re-adds the
        # body bulk so the compound = hull + 4 pads. Lowest point is the pads
        # (y=-5.0), so the lander rests on its legs instead of sinking the
        # cylinder (whose bottom is only y=-1.5) into the ground.
        def Cylinder "Hull" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            uniform token axis = "Y"
            double radius = 2.5
            double height = 3.0
            token visibility = "invisible"
            bool physics:collisionEnabled = true
        }

        # Altimeter sensor tool - raycasts downwards and outputs "range" port
        def Xform "Altimeter"
        {
            token visibility = "invisible"
            custom bool lunco:sensor:range = true
            custom token lunco:sensor:rangeAxis = "-Y"
            custom float lunco:sensor:rangeMax = 150.0
            custom token lunco:sensor:rangeOutOfRangeMode = "IdealAltitude"
            custom bool lunco:sensor:rangeVisualize = true
            custom double3 lunco:sensor:offset = (0.0, 0.0, 0.0)
            double3 xformOp:translate = (0.0, -3.3, 0.0) # centered locally at nozzle bottom
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        # ── Visual-only structure ──

        # Upper deck (flat top with instruments)
        def Cylinder "UpperDeck"
        {
            uniform token axis = "Y"
            double radius = 2.6
            double height = 0.15
            double3 xformOp:translate = (0, 1.55, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.6, 0.58, 0.55)
            bool physics:collisionEnabled = false
        }

        # Antenna mast
        def Cylinder "Antenna"
        {
            uniform token axis = "Y"
            double radius = 0.06
            double height = 2.5
            double3 xformOp:translate = (0.8, 2.8, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.7, 0.7, 0.72)
            bool physics:collisionEnabled = false
        }

        # Antenna dish
        def Sphere "AntennaDish"
        {
            double radius = 0.35
            double3 xformOp:translate = (0.8, 4.1, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.9, 0.9, 0.92)
            bool physics:collisionEnabled = false
        }

        # Engine bell / nozzle (emissive orange-red glow)
        def Cone "Nozzle"
        {
            uniform token axis = "Y"
            double radius = 1.2
            double height = 1.8
            double3 xformOp:translate = (0, -2.4, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.3, 0.28, 0.25)
            color3f primvars:emissiveColor = (0.6, 0.25, 0.05)
            bool physics:collisionEnabled = false
        }

        # Engine exhaust plume — TWO translucent emissive cones (apex DOWN, below
        # the nozzle), both DESCRIBED IN rhai (scenarios/flame.rhai), not built-in
        # Rust: the script reads the GNC `throttle` SIGNAL each tick, scales each
        # cone to match (collapsing to ~zero at idle), and adds a smoothed flicker.
        # The outer cone is a soft orange halo; the inner "...Core" is a slimmer,
        # hotter yellow-white tongue. base_color is kept DARK and the emissive is
        # HDR (>1) so the colour is the GLOW — the Sun can't wash it to tan.
        def Cone "Flame"
        {
            uniform token axis = "Y"
            double radius = 1.0
            double height = 1.0
            double3 xformOp:translate = (0, -3.5, 0)
            double3 xformOp:rotateXYZ = (180.0, 0, 0)
            double3 xformOp:scale = (0.02, 0.02, 0.02)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.5, 0.16, 0.02)
            color3f primvars:emissiveColor = (3.0, 1.0, 0.12)
            float primvars:displayOpacity = 0.4
            bool physics:collisionEnabled = false
            custom string lunco:params = "wmax=1.05, lmax=3.6, flick=1.0"
            custom string lunco:scriptPath = "scenarios/flame.rhai"
        }
        def Cone "FlameCore"
        {
            uniform token axis = "Y"
            double radius = 1.0
            double height = 1.0
            double3 xformOp:translate = (0, -3.4, 0)
            double3 xformOp:rotateXYZ = (180.0, 0, 0)
            double3 xformOp:scale = (0.02, 0.02, 0.02)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.95, 0.7, 0.2)
            color3f primvars:emissiveColor = (6.0, 3.5, 0.9)
            float primvars:displayOpacity = 0.85
            bool physics:collisionEnabled = false
            custom string lunco:params = "wmax=0.5, lmax=2.5, flick=0.5"
            custom string lunco:scriptPath = "scenarios/flame.rhai"
        }

        # Side tanks (fuel/oxidizer — 4 tanks at 90° intervals)
        def Capsule "TankPX"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 2.4
            double3 xformOp:translate = (2.2, 0.0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.75, 0.72, 0.65)
            bool physics:collisionEnabled = false
        }
        def Capsule "TankNX"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 2.4
            double3 xformOp:translate = (-2.2, 0.0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.75, 0.72, 0.65)
            bool physics:collisionEnabled = false
        }
        def Capsule "TankPZ"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 2.4
            double3 xformOp:translate = (0, 0.0, 2.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.75, 0.72, 0.65)
            bool physics:collisionEnabled = false
        }
        def Capsule "TankNZ"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 2.4
            double3 xformOp:translate = (0, 0.0, -2.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.75, 0.72, 0.65)
            bool physics:collisionEnabled = false
        }

        # ── Landing legs with footpads ──
        # Leg +X
        def Cube "LegPX"
        {
            double size = 1.0
            double3 xformOp:translate = (3.95, -1.68, 0)
            double3 xformOp:rotateXYZ = (0, 0, 25.0)
            double3 xformOp:scale = (0.15, 7.33, 0.15)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.55, 0.55, 0.57)
            bool physics:collisionEnabled = false
        }
        def Cylinder "PadPX"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 0.08
            double3 xformOp:translate = (5.5, -5.0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.45, 0.45, 0.48)
            bool physics:collisionEnabled = true
        }

        # Leg -X
        def Cube "LegNX"
        {
            double size = 1.0
            double3 xformOp:translate = (-3.95, -1.68, 0)
            double3 xformOp:rotateXYZ = (0, 0, -25.0)
            double3 xformOp:scale = (0.15, 7.33, 0.15)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.55, 0.55, 0.57)
            bool physics:collisionEnabled = false
        }
        def Cylinder "PadNX"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 0.08
            double3 xformOp:translate = (-5.5, -5.0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.45, 0.45, 0.48)
            bool physics:collisionEnabled = true
        }

        # Leg +Z
        def Cube "LegPZ"
        {
            double size = 1.0
            double3 xformOp:translate = (0, -1.68, 3.95)
            double3 xformOp:rotateXYZ = (-25.0, 0, 0)
            double3 xformOp:scale = (0.15, 7.33, 0.15)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.55, 0.55, 0.57)
            bool physics:collisionEnabled = false
        }
        def Cylinder "PadPZ"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 0.08
            double3 xformOp:translate = (0, -5.0, 5.5)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.45, 0.45, 0.48)
            bool physics:collisionEnabled = true
        }

        # Leg -Z
        def Cube "LegNZ"
        {
            double size = 1.0
            double3 xformOp:translate = (0, -1.68, -3.95)
            double3 xformOp:rotateXYZ = (25.0, 0, 0)
            double3 xformOp:scale = (0.15, 7.33, 0.15)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
            color3f primvars:displayColor = (0.55, 0.55, 0.57)
            bool physics:collisionEnabled = false
        }
        def Cylinder "PadNZ"
        {
            uniform token axis = "Y"
            double radius = 0.4
            double height = 0.08
            double3 xformOp:translate = (0, -5.0, -5.5)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f primvars:displayColor = (0.45, 0.45, 0.48)
            bool physics:collisionEnabled = true
        }
    }

    # ── The rover attached to the lander ──
    def Xform "SkidRover" (
        prepend references = @../../vessels/rovers/skid_rover.usda@</SkidRover>
    )
    {
        double3 xformOp:translate = (0, 58.35, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        double3 physics:linearVelocity = (-5.0, 0.0, -5.0)

        # Autopilot: drives the deployed rover through the waypoint course, and
        # yields to the player on any key press. Engages on the `rover_deployed`
        # event; see scenarios/rover_autopilot.rhai.
        custom string lunco:scriptPath = "scenarios/rover_autopilot.rhai"
    }

    # ── The fixed joint holding the rover and lander together ──
    def PhysicsFixedJoint "LanderRoverJoint"
    {
        rel physics:body0 = </LanderTest/Lander>
        rel physics:body1 = </LanderTest/SkidRover>
        point3f physics:localPos0 = (0, -1.5, 0)
        point3f physics:localPos1 = (0, 0.15, 0)
    }

    # ── Rover drive-to waypoints ────────────────────────────────────────────
    # Three translucent glowing domes (the same reusable marker asset) forming a
    # course. Each carries an overlap-only Sensor named "waypoint" (so they SHARE
    # an event name); the scenario distinguishes them by the emitting sensor's
    # SOURCE (via `wait_for_from`) and reveals them one at a time. Arrival is an
    # EVENT (`enter:waypoint`), never a per-tick distance poll.
    def Xform "RoverTarget1" (
        prepend references = @../../vessels/markers/waypoint.usda@</WaypointMarker>
    )
    {
        double3 xformOp:translate = (14.0, 0.0, 9.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Xform "RoverTarget2" (
        prepend references = @../../vessels/markers/waypoint.usda@</WaypointMarker>
    )
    {
        double3 xformOp:translate = (-11.0, 0.0, 16.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Xform "RoverTarget3" (
        prepend references = @../../vessels/markers/waypoint.usda@</WaypointMarker>
    )
    {
        double3 xformOp:translate = (5.0, 0.0, -15.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "LandingLocation" (
        prepend references = @../../vessels/markers/landing_location.usda@</LandingLocationMarker>
    )
    {
        double3 xformOp:translate = (0.0, 0.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def "TargetToLanderX"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "position_x"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_x"
        double lunco:scale = 1.0
    }
    def "TargetToLanderY"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "position_y"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_y"
        double lunco:scale = 1.0
    }
    def "TargetToLanderZ"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "position_z"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_z"
        double lunco:scale = 1.0
    }
    def "TargetToLanderQw"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "quat_w"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_qw"
        double lunco:scale = 1.0
    }
    def "TargetToLanderQx"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "quat_x"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_qx"
        double lunco:scale = 1.0
    }
    def "TargetToLanderQy"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "quat_y"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_qy"
        double lunco:scale = 1.0
    }
    def "TargetToLanderQz"
    {
        rel lunco:wireFrom = </LanderTest/LandingLocation/Zone>
        string lunco:fromPort = "quat_z"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "target_qz"
        double lunco:scale = 1.0
    }

    def "AltimeterToLander"
    {
        rel lunco:wireFrom = </LanderTest/Lander/Altimeter>
        string lunco:fromPort = "range"
        rel lunco:wireTo = </LanderTest/Lander>
        string lunco:toPort = "altitude"
        double lunco:scale = 1.0
    }

    # ── Mission scenario (doc 34, Decision 3) ───────────────────────────────
    # A first-class *scenario*: a non-physical prim that owns the MISSION state
    # machine. It references the vehicles by path with `find(...)` (never `me`),
    # so the orchestration is decoupled from any one entity and a scene can host
    # several scenarios / several vehicle scripts independently. The phases:
    #   descending → touchdown (PID lands, engine disarmed) → deployed
    #   (joint detached, rover falls) → finished (control handed to the player).
    # Player-task objectives (drive-to-rock, photo, thermal/energy budgets) plug
    # in as a `fn mission(me)` returning prelude `objective(...)`s — see the
    # objectives/mission engine in `crates/lunco-scripting/rhai/prelude.rhai`.
    def Scope "Scenario"
    {
        custom string lunco:scenario = "rover-surface-ops"
        # Orchestration lives in a dedicated, hot-reloadable .rhai file (loaded via
        # the AssetServer → RhaiSource → EmbeddedScenarioSource). It's a declarative
        # prelude `task` — timing from internal sim time (`wait`), advancement from
        # state predicates (`wait_until`); no tick-counting / dt integration in rhai.
        custom string lunco:scriptPath = "scenarios/rover_surface_ops.rhai"
    }
}
