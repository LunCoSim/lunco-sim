#usda 1.0
(
    defaultPrim = "ShaderFallbackTest"
    upAxis = "Y"
    metersPerUnit = 1
)

# Robustness probe: a cube that (wrongly) points its material at pbr_lit.wgsl —
# a shader LIBRARY with no @fragment entry. The app must NOT storm the pipeline
# cache; it should keep the StandardMaterial (displayColor) and warn once.
def Xform "ShaderFallbackTest"
{
    def DistantLight "Sun"
    {
        float inputs:intensity = 8000
        double3 xformOp:rotateXYZ = (-40.0, 30.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Xform "Avatar"
    {
        string lunco:avatar = "true"
        string lunco:cameraMode = "freeflight"
        custom double3 lunco:cameraLookAt = (0.0, 0.0, 0.0)
        double3 xformOp:translate = (4.0, 3.0, 6.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "BadShaderCube"
    {
        double size = 2.0
        color3f primvars:displayColor = (0.9, 0.3, 0.2)
        # INVALID: pbr_lit.wgsl is an importable library (no @fragment).
        string primvars:materialType = "shader"
        string primvars:shaderPath = "shaders/pbr_lit.wgsl"
    }
}
