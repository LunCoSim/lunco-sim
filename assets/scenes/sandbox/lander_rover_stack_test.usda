#usda 1.0
(
    defaultPrim = "LanderRoverStack"
    upAxis = "Y"
    metersPerUnit = 1
)

# A PAYLOAD bolted to a sprung vehicle — the landing gear carrying a rover.
#
# `landing_legs_test` proves the gear works on its own. This scene adds the one
# thing the mission adds: a second articulated vehicle rigidly joined to the
# hull, so the solver sees ONE island spanning the lander's four sprung legs and
# the rover's whole drivetrain. That coupling is what a mission actually flies,
# and it is a different problem from either vehicle alone — a rigid joint between
# two articulated bodies puts every joint in both of them into a single
# constraint system, where mass ratios and redundant loops that were harmless
# separately can stop being harmless.
#
# No guidance and no mission here, only the drop: anything this scene shows is
# the STACK, not the descent.
#
#   scene_test --scene scenes/sandbox/lander_rover_stack_test.usda --max-ticks 500

def Xform "LanderRoverStack" (
    kind = "assembly"
    doc = "A lander with a rover bolted underneath, dropped onto its legs."
)
{
    # UsdPhysicsScene — simulation-wide settings; bodies name it via
    # `physics:simulationOwner`. The MOON, matching the lander's own sizing.
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }

    uniform bool lunco:spawnable = false

    def Scope "PhysicsMaterials"
    {
        def Material "Friction_1_0" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1.0
            float physics:staticFriction = 1.0
        }
    }

    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.13, 0.125, 0.12)]
        bool physics:collisionEnabled = true
        rel material:binding:physics = </LanderRoverStack/PhysicsMaterials/Friction_1_0>
    }

    def DistantLight "Sun"
    {
        float inputs:intensity = 12000
        float inputs:angle = 0.53
        double3 xformOp:rotateXYZ = (-30.0, 45.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 4.0, 0.0)
        double3 xformOp:translate = (16.0, 7.0, 16.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Airframe arc only — no guidance. Pads sit at y = -5.0 in the vehicle's own
    # frame, so a hull at y = 8.0 holds them 3 m up.
    def "Lander" (
        prepend references = @lunco://vessels/landers/descent_lander.usda@</DescentLander>
    )
    {
        double3 xformOp:translate = (0, 8.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # The payload. No autopilot program: this scene tests the STRUCTURE, and a
    # rover that started driving mid-drop would be measuring something else.
    def Xform "SkidRover" (
        prepend references = @lunco://vessels/rovers/skid_rover.usda@</SkidRover>
    )
    {
        double3 xformOp:translate = (0, 6.35, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def PhysicsFixedJoint "LanderRoverJoint"
    {
        rel physics:body0 = </LanderRoverStack/Lander>
        rel physics:body1 = </LanderRoverStack/SkidRover>
        point3f physics:localPos0 = (0, -1.5, 0)
        point3f physics:localPos1 = (0, 0.15, 0)
    }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "lander-rover-stack"

        def LunCoProgram "Mission"
        {
            uniform asset info:sourceAsset = @lunco://scenarios/lander_rover_stack_test.rhai@
        }
    }
}
