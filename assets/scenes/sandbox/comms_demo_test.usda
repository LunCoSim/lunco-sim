#usda 1.0
(
    defaultPrim = "CommsDemoScene"
    upAxis = "Y"
    metersPerUnit = 1
)

# Comms connectivity demo (doc 43): a Shackleton-ridge site with a rover
# (antenna aboard), a base mast, a lunar relay satellite (ELFO) and an Earth
# DSN station. The root anchor georeferences the scene on the Moon — the site
# frame that grounds every scene-local antenna. Link state is published as a
# `LinkState` component per node (readable via `query_entity`) plus the
# `query("Links")` graph snapshot and `link.aos` / `link.los` events. Ask it from
# rhai: `can_reach("rover", "earth")` (see `scripting/prelude/links.rhai`).
def Xform "CommsDemoScene" (
    doc = "MoonDAO comms demo: Malapert Massif site with rover, base mast, lunar relay (ELFO) and the three DSN complexes on Earth — connectivity via the generic link kernel (lunco:linkNode; link.aos/link.los events)."
    prepend apiSchemas = ["LunCoCatalogAPI"]
    kind = "assembly"
)
{
    bool lunco:spawnable = false

    # This scene wants a sky: Sun, Earth and Moon. Celestial content is opt-in per
    # scene (doc 19 §11e) — the bodies, their globes, the orbit views and the
    # ephemeris all exist because these prims declare them, not because a Rust flag
    # was flipped. A scene that says nothing here gets no celestial content at all.
    def "SolarSystem" (
        prepend references = @../../celestial/solar_system.usda@</SolarSystem>
    )
    {
    }

    # Site frame: Shackleton–de Gerlache connecting ridge (Artemis site).
    # Malapert Massif summit region — the classic lunar comms-relay site:
    # near-continuous sunlight and Earth permanently a few degrees above the
    # northern horizon (direct DSN line of sight). The previous Shackleton-rim
    # point (-89.45, -136.7) sits in topographic shadow at every azimuth.
    double lunco:anchor:lat = -85.99
    double lunco:anchor:lon = 2.9
    # Height above the RENDERED moon surface. The globe tiles are a pure
    # sphere at `radius_m` (no DEM), and the site frame origin sits at
    # `radius + height` — an authored 6000 m (real Malapert altitude above
    # the reference sphere) floated the whole scene 6 km above the visible
    # surface ("terrain is not merged with lunar surface"). 0.3 m rests the
    # ground pad on the sphere without z-fighting the tangent point.
    double lunco:anchor:height = 0.3
    int lunco:anchor:body = 301
    # Local MORNING at Malapert: real ephemeris sun at +2.6° elevation and ~72°
    # in azimuth away from Earth's sky position (measured by sweeping
    # SetMissionEpoch over a lunar day). Morning beats local noon (+5.2°) for
    # the demo: at noon the sun stands next to Earth in the sky, so Earth shows
    # its NIGHT side (a black disc — "click on Earth" saw nothing); in the
    # morning Earth is a lit gibbous. Without an authored epoch the clock
    # defaults to "now", which can land in lunar polar night (pitch-black).
    double lunco:time:epochJd = 2461395.5

    def Cube "Ground" (
        prepend apiSchemas = ["LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.1, 0)
        double3 xformOp:scale = (400, 0.2, 400)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.42, 0.4, 0.38)]
        bool physics:collisionEnabled = true
    }

    def LunCoEnvironment "Environment"
    {
        # Exposure matched to grazing polar light: at the authored epoch the sun
        # sits ~2.6° above the Malapert horizon, so flat ground receives
        # 128k·sin(2.6°) ≈ 5.8k lux (luminance ≈ 740 cd/m² at regolith
        # albedo) → EV100 ≈ 12.5. The full-daylight default (~15) renders the
        # scene nearly black.
        float lunco:env:exposureEv100 = 12.5
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 xformOp:translate = (14, 6, 14)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "Rover" (
        prepend references = @../../vessels/rovers/skid_rover.usda@</SkidRover>
    )
    {
        double3 xformOp:translate = (6, 1.4, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Base comms mast — a scene-local antenna, like the moonbase one.
    def Xform "BaseMast" (
        prepend references = @../../components/comms/antenna.usda@</CommsAntenna>
    )
    {
        double3 xformOp:translate = (-8, 0, -4)
        double3 xformOp:scale = (4, 4, 4)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    # Lunar relay on its default ELFO (elements on the asset; override here to
    # reposition). Placed on the Moon's grid by the celestial systems when the
    # solar hierarchy is enabled; hidden otherwise — comms math is unaffected.
    def Xform "RelaySat" (
        prepend references = @../../vessels/satellites/relay_sat.usda@</RelaySat>
    )
    {
    }

    # Earth ground stations — the three DSN complexes, ~120° apart so at
    # least one always sees the Moon (that's WHY there are three).
    def Xform "DSS_Madrid" (
        prepend references = @../../components/comms/ground_station.usda@</GroundStation>
    )
    {
        double lunco:anchor:lat = 40.4314
        double lunco:anchor:lon = -4.2481
        double lunco:anchor:height = 837
        int lunco:anchor:body = 399
    }

    def Xform "DSS_Goldstone" (
        prepend references = @../../components/comms/ground_station.usda@</GroundStation>
    )
    {
        double lunco:anchor:lat = 35.4267
        double lunco:anchor:lon = -116.89
        double lunco:anchor:height = 1001
        int lunco:anchor:body = 399
    }

    def Xform "DSS_Canberra" (
        prepend references = @../../components/comms/ground_station.usda@</GroundStation>
    )
    {
        double lunco:anchor:lat = -35.4014
        double lunco:anchor:lon = 148.9817
        double lunco:anchor:height = 688
        int lunco:anchor:body = 399
    }

    # Connectivity is computed by the generic link kernel over the `lunco:linkNode`
    # endpoints (rover mast, base mast, relay, DSN stations) — no scenario needed;
    # the builtin `link.connected` verdict applies range / elevation / body +
    # terrain occlusion. Routing / autonomy is authored on top of its LinkState +
    # link.aos / link.los events.
}
