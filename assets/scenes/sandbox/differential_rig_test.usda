#usda 1.0
(
    defaultPrim = "DiffRigTest"
    upAxis = "Y"
    metersPerUnit = 1
)

# G5 isolated differential test — coupling ON. See differential_rig.usda.
#   sandbox --scene scenes/sandbox/differential_rig_test.usda
# Verify (ListPorts): HingeR.angle ≈ −HingeL.angle (rocker B mirrors A).

def Xform "DiffRigTest"
{
    custom bool lunco:spawnable = false

    def Cube "Ground" (prepend apiSchemas = ["PhysicsCollisionAPI", "PhysxTerrainAPI"])
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f primvars:displayColor = (0.4, 0.4, 0.45)
        bool physics:collisionEnabled = true
        float physics:friction = 1.0
    }
    def DistantLight "Sun"
    {
        float inputs:intensity = 10000
        double3 xformOp:rotateXYZ = (-35.0, 40.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }
    def Xform "Avatar"
    {
        string lunco:avatar = "true"
        string lunco:cameraMode = "freeflight"
        double3 xformOp:translate = (6.0, 4.0, 7.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Xform "Rig" (
        prepend references = @../../vessels/rovers/differential_rig.usda@</DiffRig>
    )
    {
        double3 xformOp:translate = (0, 1.5, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
