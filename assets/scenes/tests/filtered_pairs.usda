#usda 1.0
(
    defaultPrim = "SandboxScene"
    upAxis = "Y"
    metersPerUnit = 1
)

# Verifies `PhysicsFilteredPairsAPI` — an AUTHORED pair that must never collide.
#
# The rig is `vessels/rigs/filtered_pair_rig.usda`, referenced (not copied): a pad
# authored 0.5 m inside a hull it is TWO JOINTS away from, so nothing but an
# authored pair can stop them touching. Its control,
# `filtered_pairs_unfiltered.usda`, references the same rig and authors no
# filtering — so the `over` below is the ONLY difference between the two scenes.
#
# What is measured is the CONTACT, not its aftermath: the Pad carries
# `lunco:sensor:contact`, so the test reads whether the pair exists rather than
# guessing from how far something moved.
#
# Read live:  ListPorts -> Rig/Pad exposes `contact` and `contact_force`.
# Loaded by `sandbox --scene scenes/tests/filtered_pairs.usda`.

def Xform "SandboxScene" (
    kind = "assembly"
    doc = "A pad bolted to an arm bolted to a hull, with the pad deliberately overlapping the hull. Checks that an authored never-collide pair really does stop the two touching."
    prepend apiSchemas = ["LunCoCatalogAPI"]
)
{
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }

    uniform bool lunco:spawnable = false

    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.4, 0.4, 0.45)]
        bool physics:collisionEnabled = true
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 6.0, 0.0)
        double3 xformOp:translate = (0.0, 8.0, 10.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Held 6 m up, clear of the ground: the only contact anything in the rig can
    # have is with itself. A contact sensor that could also feel the floor would
    # prove nothing about the pair.
    def Xform "Rig" (
        prepend references = @lunco://vessels/rigs/filtered_pair_rig.usda@</FilteredPairRig>
    )
    {
        double3 xformOp:translate = (0, 6.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # THE THING UNDER TEST, and the only difference from the control scene.
        # Filtering is symmetric, so one opinion is the whole pair — the Hull
        # authors nothing.
        over "Pad" (
            prepend apiSchemas = ["PhysicsFilteredPairsAPI"]
        )
        {
            rel physics:filteredPairs = </SandboxScene/Rig/Hull>
        }
    }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "filtered-pairs"

        def LunCoProgram "Test"
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/filtered_pairs.rhai@
            # WHICH case this is, declared rather than sniffed: 1 = the pair is
            # authored and must not collide, 0 = the control.
            custom float lunco:param:filtered = 1.0
        }
    }
}
