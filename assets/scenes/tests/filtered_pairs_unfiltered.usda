#usda 1.0
(
    defaultPrim = "SandboxScene"
    upAxis = "Y"
    metersPerUnit = 1
)

# The CONTROL for `filtered_pairs.usda`: the SAME rig
# (`vessels/rigs/filtered_pair_rig.usda`, referenced), with no filtering authored
# on it at all.
#
# It is half the test. "The pad reports no contact" passes trivially on a rig
# whose parts never touched — a typo in a translate, a joint that never built, a
# collider that never loaded, and the filtered scene still goes green while
# proving nothing. This scene is what shows the measurement can tell the
# difference: with no rel, the very same sensor must read a contact.
#
# The geometry cannot drift between the two scenes, because there is only one
# copy of it. The difference is one `over` in the other file, and nothing here.
#
# Loaded by `sandbox --scene scenes/tests/filtered_pairs_unfiltered.usda`.

def Xform "SandboxScene" (
    kind = "assembly"
    doc = "The never-collide pair test with the pairing removed, so the overlapping parts collide as usual. Shows what the authored pair does by showing what happens without it."
    prepend apiSchemas = ["LunCoCatalogAPI"]
)
{
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }

    uniform bool lunco:spawnable = false

    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.4, 0.4, 0.45)]
        bool physics:collisionEnabled = true
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 6.0, 0.0)
        double3 xformOp:translate = (0.0, 8.0, 10.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Xform "Rig" (
        prepend references = @lunco://vessels/rigs/filtered_pair_rig.usda@</FilteredPairRig>
    )
    {
        double3 xformOp:translate = (0, 6.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "filtered-pairs"

        def Scope "Test" (
            prepend apiSchemas = ["LunCoProgramAPI"]
        )
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/filtered_pairs.rhai@
            custom float lunco:param:filtered = 0.0
        }
    }
}
