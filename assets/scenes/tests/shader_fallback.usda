#usda 1.0
(
    defaultPrim = "ShaderFallbackTest"
    upAxis = "Y"
    metersPerUnit = 1
)

# Robustness probe: a cube that (wrongly) points its material at pbr_lit.wgsl —
# a shader LIBRARY with no @fragment entry. The app must NOT storm the pipeline
# cache; it should keep the StandardMaterial (displayColor) and warn once.
# Scene root: an `assembly` — a thing you OPEN, not a part you place.
def Xform "ShaderFallbackTest" (
    kind = "assembly"
    doc = "Robustness probe: a cube that wrongly points its material at a shader library with no fragment entry. The app must keep the StandardMaterial and warn once instead of storming the pipeline cache."
)
{
    # NOT headless-testable — see `lunco:notHeadlessTestable` in `hdri.usda` for
    # why the reason lives in the scene rather than in two exception lists.
    custom string lunco:notHeadlessTestable = "a render check: asserts what a material looks like when its shader is missing"


    # UsdPhysicsScene — simulation-wide settings. ONE per scene: this engine
    # reads gravity from it and applies it to every body, so a second scene prim
    # would be a second answer to the same question. Earth gravity, which this scene's vehicles and their
    # tuning are authored against — stated here rather than left to a default.
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }
    def DistantLight "Sun"
    {
        float inputs:intensity = 8000
        double3 xformOp:rotateXYZ = (-40.0, 30.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 0.0, 0.0)
        double3 xformOp:translate = (4.0, 3.0, 6.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Scope "Looks"
    {
        def Material "BadShader"
        {
            token outputs:surface.connect = </ShaderFallbackTest/Looks/BadShader/Shader.outputs:surface>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                # INVALID: pbr_lit.wgsl is an importable library (no @fragment).
                uniform asset info:wgsl:sourceAsset = @lunco://shaders/pbr_lit.wgsl@
                token outputs:surface
            }
        }
    }

    def Cube "BadShaderCube"
    {
        double size = 2.0
        color3f[] primvars:displayColor = [(0.9, 0.3, 0.2)]
        rel material:binding = </ShaderFallbackTest/Looks/BadShader>
    }
}
