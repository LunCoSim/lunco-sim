#usda 1.0
(
    defaultPrim = "RoverComparison"
    upAxis = "Y"
    metersPerUnit = 1
)

# Seven vehicle architectures traverse one identical, composed primitive course
# in parallel.  There is one course definition and one shared material; lanes
# differ only by X translation and vehicle reference.
def Xform "RoverComparison" (
    kind = "assembly"
    doc = "Parallel rover suspension, traction, grade and drivetrain comparison."
    prepend apiSchemas = ["LunCoCatalogAPI"]
)
{
    uniform bool lunco:spawnable = false

    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }
    def Scope "PhysicsMaterials"
    {
        def Material "Regolith" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
            prepend variantSets = "surfaceGrip"
            variants = { string surfaceGrip = "nominal" }
        )
        {
            variantSet "surfaceGrip" = {
                "slippery" { float physics:staticFriction = 0.35; float physics:dynamicFriction = 0.28 }
                "nominal" { float physics:staticFriction = 0.8; float physics:dynamicFriction = 0.8 }
                "highGrip" { float physics:staticFriction = 1.2; float physics:dynamicFriction = 1.0 }
            }
        }
    }
    def Cube "Ground" (prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"])
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (140, 1, 160)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.24, 0.22, 0.19)]
        bool physics:collisionEnabled = true
        rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>
    }
    def DistantLight "Sun"
    {
        float inputs:intensity = 128000
        float inputs:angle = 0.53
        double3 xformOp:rotateXYZ = (-35, 40, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }
    def Xform "Avatar" (prepend apiSchemas = ["LunCoAvatarAPI"])
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0, 1, 4)
        double3 xformOp:translate = (0, 26, 48)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Routes are world-space, one per rover.  They are mission data, never a
    # child of a moving vehicle.  The editor shows only the selected/possessed
    # vehicle's route and derives its colour from that vehicle's USD body livery.
    def Scope "Routes"
    {
        def Scope "Easy" { def Xform "P0" { double3 xformOp:translate = (-42,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (-42,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (-42,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (-42,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (-42,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "Medium" { def Xform "P0" { double3 xformOp:translate = (-28,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (-28,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (-28,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (-28,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (-28,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "Awful" { def Xform "P0" { double3 xformOp:translate = (-14,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (-14,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (-14,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (-14,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (-14,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "Conventional" { def Xform "P0" { double3 xformOp:translate = (0,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (0,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (0,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (0,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (0,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "Skid4" { def Xform "P0" { double3 xformOp:translate = (14,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (14,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (14,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (14,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (14,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "AckermannRaycast4" { def Xform "P0" { double3 xformOp:translate = (28,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (28,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (28,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (28,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (28,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
        def Scope "AckermannJoint4" { def Xform "P0" { double3 xformOp:translate = (42,1.2,30); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P1" { double3 xformOp:translate = (42,1.2,10); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P2" { double3 xformOp:translate = (42,1.2,-9); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P3" { double3 xformOp:translate = (42,2.6,-16); uniform token[] xformOpOrder = ["xformOp:translate"] } def Xform "P4" { double3 xformOp:translate = (42,1.2,-24); uniform token[] xformOpOrder = ["xformOp:translate"] } }
    }

    def Xform "EasyCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (-42,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "Easy" (prepend references = @lunco://vessels/rovers/variants/rover_easy.usda@</RoverEasy>) { double3 xformOp:translate = (-42,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_easy.btxml@ } }
    def Xform "MediumCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (-28,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "Medium" (prepend references = @lunco://vessels/rovers/variants/rover_medium.usda@</RoverMedium>) { double3 xformOp:translate = (-28,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_medium.btxml@ } }
    def Xform "AwfulCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (-14,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "Awful" (prepend references = @lunco://vessels/rovers/variants/rover_awful.usda@</RoverAwful>) { double3 xformOp:translate = (-14,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_awful.btxml@ } }
    def Xform "ConventionalCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (0,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "Conventional" (prepend references = @lunco://vessels/rovers/six_wheel_rover.usda@</SixWheelRover>) { double3 xformOp:translate = (0,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_conventional.btxml@ } }
    def Xform "SkidCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (14,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "SkidFourWheel" (prepend references = @lunco://vessels/rovers/skid_rover.usda@</SkidRover>) { double3 xformOp:translate = (14,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_skid4.btxml@ } }
    def Xform "AckermannCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (28,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "AckermannRaycast4" (prepend references = @lunco://vessels/rovers/ackermann_rover.usda@</AckermannRover>) { variants = { string drivetrain = "raycast" }; double3 xformOp:translate = (28,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_ackermann_raycast4.btxml@ } }
    def Xform "AckermannPhysicalCourse" (prepend references = @lunco://components/terrain/rocker_bogie_articulation_course.usda@</RockerBogieArticulationCourse>) { rel material:binding:physics = </RoverComparison/PhysicsMaterials/Regolith>; double3 xformOp:translate = (42,0,0); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Xform "AckermannJoint4" (prepend references = @lunco://vessels/rovers/ackermann_rover.usda@</AckermannRover>) { variants = { string drivetrain = "physical" }; double3 xformOp:translate = (42,1.6,32); uniform token[] xformOpOrder = ["xformOp:translate"]; def Scope "Mission" (prepend apiSchemas = ["LunCoProgramAPI"]) { uniform asset info:sourceAsset = @lunco://behaviors/rover_comparison_ackermann_joint4.btxml@ } }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "rover-comparison"
        def Scope "Test" (prepend apiSchemas = ["LunCoProgramAPI"])
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/rover_comparison.rhai@
        }
    }
}

