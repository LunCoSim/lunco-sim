#usda 1.0
(
    defaultPrim = "AllocationSpec"
    upAxis = "Y"
    metersPerUnit = 1
)

# ── Drive-allocation spec rig ────────────────────────────────────────────────
#
# The scene `scenarios/tests/allocation_spec.rhai` runs against. It exists because the
# allocation spec needs TWO rovers that differ in exactly ONE authored opinion:
# the name of their drive kernel.
#
#   RoverSkid   — stock `vessels/rovers/skid_rover.usda`. Its
#                 `PhysxVehicleTankDifferentialAPI` derives `DriveMix::skid`, so
#                 `DriveMix.kernel == "skid"` and the name resolves in the
#                 `ControlKernelRegistry`. Every allocation assertion (named
#                 ports, forward/reverse mirror, counter-rotation, steer
#                 priority) is measured on this one.
#
#   RoverBogus  — the SAME asset with one attribute added: a `lunco:driveKernel`
#                 naming a kernel that does not exist, in the registry or as a
#                 rhai hook. It is the scenario-level form of the unit test's
#                 `reg.get("nope").is_none()`.
#
# WHY THE BOGUS ROVER IS WORTH A WHOLE PRIM. The lookup MISS is not an academic
# case — it is a load-bearing mechanism. `components/mobility/drive_laws/*.usda`
# deliberately author `lunco:driveKernel = "external"`, a name that resolves to
# nothing, precisely so the built-in mixing stands down and a Modelica drive law
# owns the drive ports alone. If an unknown kernel ever started falling back to
# skid instead of coasting, every Modelica-driven rover would silently acquire a
# second writer on its ports. So this rig asserts the FAIL-SAFE, not merely the
# lookup: under full throttle, a rover with an unresolvable kernel does not move.
#
# The two rovers are 50 m apart in X and drive along -Z, so their paths never
# meet. Geometry, ground, friction and spawn height are copied from
# `drivetrain_parity.usda` — a rig whose numbers are already known-good — so the
# only new variable in this scene is the kernel name.
#
#     sandbox --scene scenes/tests/allocation_spec.usda

def Xform "AllocationSpec" (
    kind = "assembly"
    doc = "Two skid rovers differing only in drive-kernel name — one resolvable, one not — for the drive-allocation spec."
    prepend apiSchemas = ["LunCoCatalogAPI"]
)
{

    # UsdPhysicsScene — simulation-wide settings. ONE per scene: this engine
    # reads gravity from it and applies it to every body, so a second scene prim
    # would be a second answer to the same question. Earth gravity, which this scene's vehicles and their
    # tuning are authored against — stated here rather than left to a default.
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }
    # A test rig, not a spawnable part.
    uniform bool lunco:spawnable = false

    # ONE friction material under BOTH rovers. The bogus rover's assertion is
    # "it did not move", which a different surface under it would trivially
    # satisfy for the wrong reason.
    def Scope "PhysicsMaterials"
    {
        def Material "Friction_1_0" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1.0
            float physics:staticFriction = 1.0
        }
    }

    # Flat, level, 500 x 500 m. Level matters here more than usual: on a slope an
    # un-actuated rover ROLLS, and "the fail-safe coasted" would be
    # indistinguishable from "gravity moved it".
    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (500.0, 1.0, 500.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.4, 0.4, 0.45)]
        bool physics:collisionEnabled = true
        rel material:binding:physics = </AllocationSpec/PhysicsMaterials/Friction_1_0>
    }

    def DistantLight "Sun"
    {
        float inputs:intensity = 128000
        float inputs:angle = 0.53
        double3 xformOp:rotateXYZ = (-35.0, 40.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 1.0, 100.0)
        double3 xformOp:translate = (0.0, 30.0, 175.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # Broadside: both rovers in frame for the whole run, so a human can SEE that
    # one of them drove off and the other sat still.
    def Camera "SpecCam"
    {
        custom double3 lunco:cameraLookAt = (0.0, 1.0, 90.0)
        double3 xformOp:translate = (0.0, 45.0, 190.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        float focalLength = 24.0
        float2 clippingRange = (0.1, 100000.0)
    }

    # ── The measured rover ───────────────────────────────────────────────────
    # Stock skid rover. `drivetrain = "raycast"` is the asset's own fallback but
    # is written out explicitly: the spec measures wheel spin off
    # `WheelRaycast.spin_velocity`, so the realization is not an incidental
    # detail of this rig, it is a precondition of the measurement.
    def Xform "RoverSkid" (
        prepend references = @lunco://vessels/rovers/skid_rover.usda@</SkidRover>
        variants = {
            string drivetrain = "raycast"
        }
    )
    {
        double3 xformOp:translate = (-25.0, 1.0, 120.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        over "Chassis"
        {
            color3f[] primvars:displayColor = [(0.85, 0.35, 0.15)]
        }
    }

    # ── The fail-safe control ────────────────────────────────────────────────
    # Identical in every respect but one. `lunco:driveKernel` takes precedence
    # over the inherited `PhysxVehicleTankDifferentialAPI` in `derive_drive_mix`,
    # so this rover composes a `DriveMix { kernel: <this name>, ports: [],
    # entries: [] }`. `apply_drive_mix` then finds no built-in and no rhai hook,
    # warns ONCE, and writes no port.
    #
    # The name is deliberately grotesque. A plausible one ("skid2", "tank") is a
    # name somebody might one day register for real, which would turn this test
    # green by making its premise false.
    def Xform "RoverBogus" (
        prepend references = @lunco://vessels/rovers/skid_rover.usda@</SkidRover>
        variants = {
            string drivetrain = "raycast"
        }
    )
    {
        string lunco:driveKernel = "no_such_kernel__failsafe_probe"

        double3 xformOp:translate = (25.0, 1.0, 120.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        over "Chassis"
        {
            color3f[] primvars:displayColor = [(0.15, 0.45, 0.85)]
        }
    }

    # ── The test itself ──────────────────────────────────────────────────────
    # A non-physical prim owning the harness and reaching both rovers by path,
    # rather than hanging off either one: the two rovers must differ in exactly
    # one opinion, and hosting the program on one of them is a second.
    def Scope "Scenario"
    {
        custom string lunco:scenario = "allocation-spec"

        def LunCoProgram "AllocationSpec"
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/allocation_spec.rhai@
        }
    }
}
