#usda 1.0
(
    defaultPrim = "SandboxScene"
    upAxis = "Y"
    metersPerUnit = 1
)

# Minimal scene verifying the PRISMATIC joint cosim port + the standard
# UsdPhysics drive schema (gap G9 — generic joint actuation).
#
#   - Ground   (static collider)
#   - Base     (kinematic, fixed in space — body0)
#   - Platform (dynamic — body1), 2 m below the Base, free to slide along Y
#   - Lift     (PhysicsPrismaticJoint, slider axis Y) joining Base & Platform,
#              with a UsdPhysicsDriveAPI:linear position drive
#
# Two things are exercised:
#   1. USD-native standalone drive. `PhysicsDriveAPI:linear` authors
#      `physics:targetPosition = -1.5` + `physics:maxForce`, so at load the
#      Avian LinearMotor is enabled and the Platform seeks -1.5 m and HOLDS
#      there against gravity — no wire needed. (Remove the drive and the
#      Platform free-falls along the slider, proving the drive is what holds it.)
#   2. Live cosim port. The joint auto-exposes port `displacement` (the runtime
#      face of PhysxJointStateAPI:linear position / PhysicsDriveAPI:linear
#      targetPosition):
#         SetPort {api_id:<Lift>, name:"displacement", value:-0.5}  -> Platform rises to -0.5 m
#         GetPort {api_id:<Lift>, name:"displacement"}              -> measured offset (m)
#
# Loaded by `sandbox --scene scenes/tests/prismatic_drive.usda`.

# Scene root: an `assembly` — a thing you OPEN, not a part you place.
def Xform "SandboxScene" (
    kind = "assembly"
    doc = "A platform that slides up and down a vertical rail. Checks that a motorized slider can move to a chosen height and hold there against gravity."
    prepend apiSchemas = ["LunCoCatalogAPI"]
)
{

    # UsdPhysicsScene — simulation-wide settings. ONE per scene: this engine
    # reads gravity from it and applies it to every body, so a second scene prim
    # would be a second answer to the same question. Earth gravity, which this scene's vehicles and their
    # tuning are authored against — stated here rather than left to a default.
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }

    # UsdPhysicsMaterialAPI — friction/restitution live on a Material
    # bound with the purpose-specific `material:binding:physics`, which is
    # how UsdPhysics (and Omniverse) actually spell a surface.
    def Scope "PhysicsMaterials"
    {
        def Material "Friction_1_0" (
            prepend apiSchemas = ["PhysicsMaterialAPI"]
        )
        {
            float physics:dynamicFriction = 1.0
            float physics:staticFriction = 1.0
        }
    }
    uniform bool lunco:spawnable = false

    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI", "LunCoTerrainAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (200.0, 1.0, 200.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.4, 0.4, 0.45)]
        bool physics:collisionEnabled = true
        rel material:binding:physics = </SandboxScene/PhysicsMaterials/Friction_1_0>
    }

    # Avatar so the API observer has someone to focus from.
    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 5.0, 0.0)
        double3 xformOp:translate = (0.0, 6.0, 12.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Cube "Base" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        double size = 0.6
        double3 xformOp:translate = (0.0, 6.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(1.0, 0.2, 0.2)]
        float physics:mass = 1.0
        bool physics:kinematicEnabled = true
    }

    def Xform "Platform" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        # A body prim is a FRAME, not a mesh: the shaping scale lives on the shape
        # below, so this prim's frame stays usable by anything mounted in it.
        double3 xformOp:translate = (0.0, 4.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        float physics:mass = 50.0

        def Cube "Shape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 0.5
            double3 xformOp:scale = (1.6, 0.3, 1.6)
            color3f[] primvars:displayColor = [(0.2, 0.6, 1.0)]
            uniform token[] xformOpOrder = ["xformOp:scale"]
        }
    }

    def PhysicsPrismaticJoint "Lift" (
        prepend apiSchemas = ["PhysicsDriveAPI:linear"]
    )
    {
        rel physics:body0 = </SandboxScene/Base>
        rel physics:body1 = </SandboxScene/Platform>
        uniform token physics:axis = "Y"
        # Base anchor at its centre (world 0,6,0); Platform's anchor is +2 along
        # Y so the two coincide at rest -> displacement 0 when undriven.
        point3f physics:localPos0 = (0.0, 0.0, 0.0)
        point3f physics:localPos1 = (0.0, 2.0, 0.0)
        float physics:lowerLimit = -3.0
        float physics:upperLimit = 0.5

        # UsdPhysicsDriveAPI:linear — standard position drive. Enabled at load
        # (a target is authored), so the Platform deploys to -1.5 m and holds.
        float drive:linear:physics:targetPosition = -1.5
        float drive:linear:physics:maxForce = 5000.0
    }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "prismatic-drive"

        def LunCoProgram "Test"
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/prismatic_drive.rhai@
        }
    }
}
