#usda 1.0
(
    defaultPrim = "PrismaticSpringTest"
    upAxis = "Y"
    metersPerUnit = 1
)

# Two raked prismatic springs, one mass on each. Nothing else.
#
# This is the instrument, not a vehicle. A landing leg lives inside a mechanism —
# four raked sliders, four gimballed pads, four ground contacts, a hull — and when
# such a gear does not stroke there are two very different explanations:
#
#   1. the JOINT does not do what it was authored to do (a loader or frame bug), or
#   2. the joint is fine and the MECHANISM around it is over-constrained.
#
# No measurement taken on the vehicle can separate those, because every one of them
# is taken through the mechanism. This scene removes the mechanism: kinematic
# anchors, prismatic joints raked 25° off vertical exactly like a leg, and one mass
# on the end of each. There is no contact, no friction, no second load path, no
# redundancy. If a strut does not stroke HERE, the joint is broken; if it does,
# the joint is not what is wrong with the gear.
#
#   scene_test --scene scenes/tests/prismatic_spring.usda --max-ticks 400
#
# EXPECTED, and it is arithmetic rather than a tolerance pulled from a run:
#
#   weight along the strut axis   m·g·cos(25°) = 500 · 1.62 · 0.90631 = 734.1 N
#   travel                        F / k        = 734.1 / 4000         = 0.1835 m
#
# with the SIGN set by which way the load pushes: +0.1835 m for the strut being
# extended, -0.1835 m for the strut being compressed. Both are here, because the
# sign is the part a landing leg gets wrong: a leg authors its travel as
# `lowerLimit = -0.8, upperLimit = 0.0`, which is only soft if compression really
# is the negative direction. If it is not, the leg is jammed at zero travel and
# carries the vehicle rigidly while reporting no spring force at all.

def Xform "PrismaticSpringTest" (
    kind = "assembly"
    doc = "Raked prismatic springs under known loads — the landing-leg joint, isolated, in both regimes."
)
{
    # Moon, matching the vehicles this joint is authored for, so the expected
    # compression above is the one the gear is actually sized against.
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, -1, 0)
        float physics:gravityMagnitude = 1.62
    }
    uniform bool lunco:spawnable = false

    def DistantLight "Sun"
    {
        float inputs:intensity = 12000
        double3 xformOp:rotateXYZ = (-30.0, 45.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Xform "Avatar" (
        prepend apiSchemas = ["LunCoAvatarAPI"]
    )
    {
        uniform bool lunco:avatar = true
        uniform token lunco:cameraMode = "freeflight"
        double3 lunco:cameraLookAt = (0.0, 9.0, 0.0)
        double3 xformOp:translate = (6.0, 10.0, 6.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # The ground the mass must NOT reach. Ten metres below the rest pose and
    # fifty times the expected stroke away: if the bob ever touches it, the
    # spring failed open, and the height check in the scenario says so.
    def Cube "Ground" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0, -0.5, 0)
        double3 xformOp:scale = (50.0, 1.0, 50.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.13, 0.125, 0.12)]
        bool physics:collisionEnabled = true
    }

    # TWO struts, because a spring has two regimes and a landing leg only ever
    # uses one of them. Both are the same joint with the same stiffness; they
    # differ only in which side of the anchor the mass sits on, and therefore in
    # whether the load EXTENDS the strut or COMPRESSES it.
    #
    # The sign convention this pins down: displacement is measured along the
    # joint frame's axis, which points body0 → body1. A mass that moves FURTHER
    # along that axis extends the strut and reads POSITIVE; a mass pushed back
    # toward body0 compresses it and reads NEGATIVE. A landing leg is the second
    # case — its axis points hull → foot, and the ground pushes the foot back up
    # toward the hull — which is why every leg authors `lowerLimit = -0.8,
    # upperLimit = 0.0`. Get that backwards and the leg is not soft: it is jammed
    # against a limit at zero travel, carrying the vehicle on a rigid constraint
    # while its spring reports nothing.
    #
    # Both bobs are 500 kg and sit one metre from their anchor along the rake, so
    # each is at displacement 0 in the authored pose:
    #
    #   rake, extending:   (sin25, -cos25, 0) = ( 0.42262, -0.90631, 0)
    #   rake, compressing: (sin25,  cos25, 0) = ( 0.42262,  0.90631, 0)

    # ── Extension: the bob hangs BELOW its anchor ────────────────────────────
    def Xform "AnchorExt" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI"]
    )
    {
        # A body prim is a FRAME, not a mesh: the shaping scale lives on the shape
        # below, so this prim's frame stays usable by anything mounted in it.
        double3 xformOp:translate = (-3.0, 10.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        bool physics:kinematicEnabled = true

        def Cube "Shape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.6, 0.3, 0.6)
            color3f[] primvars:displayColor = [(0.35, 0.36, 0.4)]
            uniform token[] xformOpOrder = ["xformOp:scale"]
        }
    }

    def Sphere "BobExt" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double radius = 0.35
        double3 xformOp:translate = (-2.57738, 9.09369, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.85, 0.55, 0.2)]
        float physics:mass = 500.0
        bool physics:collisionEnabled = true
    }

    # Axis +Y of the frame onto (0.42262, -0.90631, 0): 205° about Z.
    # Half-angle 102.5°, cos = -0.216440, sin = 0.976296. Quaternion (w, x, y, z).
    def PhysicsPrismaticJoint "StrutExt" (
        prepend apiSchemas = ["PhysicsDriveAPI:linear"]
    )
    {
        rel physics:body0 = </PrismaticSpringTest/AnchorExt>
        rel physics:body1 = </PrismaticSpringTest/BobExt>
        uniform token physics:axis = "Y"
        quatf physics:localRot0 = (-0.216440, 0, 0, 0.976296)
        quatf physics:localRot1 = (-0.216440, 0, 0, 0.976296)
        float physics:lowerLimit = -1.0
        float physics:upperLimit = 1.0
        uniform token drive:linear:physics:type = "force"
        float drive:linear:physics:stiffness = 4000.0
        float drive:linear:physics:damping = 2200.0
        float drive:linear:physics:targetPosition = 0.0
        float drive:linear:physics:maxForce = 20000.0
    }

    # ── Compression: the bob sits ABOVE its anchor — the landing-leg regime ───
    def Xform "AnchorComp" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI"]
    )
    {
        # A body prim is a FRAME, not a mesh: the shaping scale lives on the shape
        # below, so this prim's frame stays usable by anything mounted in it.
        double3 xformOp:translate = (3.0, 8.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        bool physics:kinematicEnabled = true

        def Cube "Shape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.6, 0.3, 0.6)
            color3f[] primvars:displayColor = [(0.35, 0.36, 0.4)]
            uniform token[] xformOpOrder = ["xformOp:scale"]
        }
    }

    def Sphere "BobComp" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double radius = 0.35
        double3 xformOp:translate = (3.42262, 8.90631, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.3, 0.7, 0.9)]
        float physics:mass = 500.0
        bool physics:collisionEnabled = true
    }

    # Axis +Y of the frame onto (0.42262, 0.90631, 0): -25° about Z.
    # Half-angle -12.5°, cos = 0.976296, sin = -0.216440.
    def PhysicsPrismaticJoint "StrutComp" (
        prepend apiSchemas = ["PhysicsDriveAPI:linear"]
    )
    {
        rel physics:body0 = </PrismaticSpringTest/AnchorComp>
        rel physics:body1 = </PrismaticSpringTest/BobComp>
        uniform token physics:axis = "Y"
        quatf physics:localRot0 = (0.976296, 0, 0, -0.216440)
        quatf physics:localRot1 = (0.976296, 0, 0, -0.216440)
        float physics:lowerLimit = -1.0
        float physics:upperLimit = 1.0
        uniform token drive:linear:physics:type = "force"
        float drive:linear:physics:stiffness = 4000.0
        float drive:linear:physics:damping = 2200.0
        float drive:linear:physics:targetPosition = 0.0
        float drive:linear:physics:maxForce = 20000.0
    }

    # ── The leg convention: two DIFFERENT joint frames ───────────────────────
    #
    # The two struts above set `localRot0 == localRot1`, which is the easy case:
    # both bodies rest at the same orientation, so any error in how the basis is
    # applied cancels between the frames and is invisible.
    #
    # A landing leg is NOT that case. Its strut body carries the 25° rake as its
    # own `xformOp:rotateXYZ`, so the joint's two frames differ — `localRot0` is
    # 205° about Z (hull side, taking +Y onto the hull→foot direction) while
    # `localRot1` is the 180° flip alone (leg side, because the body already
    # holds the 25°). Their PRODUCT with each body's rest orientation agrees,
    # which is what a prismatic requires; the individual quaternions do not.
    #
    # This strut reproduces that exactly, with the same mass and stiffness as the
    # other two, so the direction it slides along is measurable in isolation:
    #
    #   raked axis, as authored:   axial load = m·g·cos25° = 734.1 N → 0.1835 m
    #   vertical axis, if the rake is lost:   m·g          = 810.0 N → 0.2025 m
    #
    # and the bob's horizontal travel separates them outright: a raked axis moves
    # it 0.0776 m in X, a vertical one moves it not at all.
    def Xform "AnchorLegLike" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI"]
    )
    {
        # A body prim is a FRAME, not a mesh: the shaping scale lives on the shape
        # below, so this prim's frame stays usable by anything mounted in it.
        double3 xformOp:translate = (0, 10.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        bool physics:kinematicEnabled = true

        def Cube "Shape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.6, 0.3, 0.6)
            color3f[] primvars:displayColor = [(0.35, 0.36, 0.4)]
            uniform token[] xformOpOrder = ["xformOp:scale"]
        }
    }

    # Rotated 25° about Z in its own right — exactly as a leg strut is — so the
    # joint's two frames must differ to describe the same rest orientation.
    def Cube "BobLegLike" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysicsCollisionAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:translate = (0.42262, 9.09369, 0)
        double3 xformOp:rotateXYZ = (0, 0, 25.0)
        double3 xformOp:scale = (0.5, 0.5, 0.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.6, 0.85, 0.4)]
        float physics:mass = 500.0
        bool physics:collisionEnabled = true
    }

    def PhysicsPrismaticJoint "StrutLegLike" (
        prepend apiSchemas = ["PhysicsDriveAPI:linear"]
    )
    {
        rel physics:body0 = </PrismaticSpringTest/AnchorLegLike>
        rel physics:body1 = </PrismaticSpringTest/BobLegLike>
        uniform token physics:axis = "Y"
        quatf physics:localRot0 = (-0.216440, 0, 0, 0.976296)
        quatf physics:localRot1 = (0, 0, 0, 1)
        float physics:lowerLimit = -1.0
        float physics:upperLimit = 1.0
        uniform token drive:linear:physics:type = "force"
        float drive:linear:physics:stiffness = 4000.0
        float drive:linear:physics:damping = 2200.0
        float drive:linear:physics:targetPosition = 0.0
        float drive:linear:physics:maxForce = 20000.0
    }

    def Scope "Scenario"
    {
        custom string lunco:scenario = "prismatic-spring"

        def LunCoProgram "Mission"
        {
            uniform asset info:sourceAsset = @lunco://scenarios/tests/prismatic_spring.rhai@
        }
    }
}
