#usda 1.0
(
    defaultPrim = "Drivetrain"
    upAxis = "Y"
    metersPerUnit = 1
)

# Shared JOINT-BASED drivetrain — referenced into the `physical` variant of
# every rover (skid + ackermann) so the joint rig is authored ONCE.
#
# `Drivetrain` is a neutral stand-in for the rover root: it owns no wheels of
# its own — it carries only the revolute joints + the articulation-root schema.
# When a rover's `physical` variant references this prim, the arc
# path-translates `</Drivetrain/...>` onto the rover root (`</SkidRover/...>`);
# referencing that rover into a scene translates a second time
# (`</SandboxScene/Skid_Physical_1/...>`). The wheel prims the joint targets
# point at are supplied by the rover, not here.
#
# IT DOES NOT PLACE THE WHEELS. It used to carry `over "Wheel_*"` translates
# (y=-0.65) against `raycast_drivetrain.usda`'s (y=-0.15), which made the wheel
# prim mean the axle in one realization and the strut top in the other: one
# rover, two ride heights, two centre-of-mass heights. The mount belongs to the
# VEHICLE and is authored on the rover (`skid_rover.usda` / `ackermann_rover.usda`).
# The drop those `over`s used to state now lives there and is the SAME number:
# chassis half-height 0.15 ⇒ bottom at y=-0.15; wheels at y=-0.65 (Ø0.8 → top at
# y=-0.25) clear it by 0.10 m, so the wheel colliders never touch the body and the
# joints stay stable without relying on collision-disable.
#
# NOT `lunco:spawnable`. This asset is an OVERLAY: the joints target wheels that must
# ALREADY exist on the host. Spawned on its own it would leave a bare articulation root
# with joints pointing at prims that do not exist. It arrives on a `references` arc onto
# a rover that has wheels.
#
# `PhysicsArticulationRootAPI` STAYS — that is what this prim is. Only the catalogue
# claim goes.
def Xform "Drivetrain" (
    kind = "component"
    prepend apiSchemas = ["PhysicsArticulationRootAPI"]
)
{
    # Each wheel is bound to the rover root by a `PhysicsRevoluteJoint` with a
    # `PhysicsDriveAPI:angular` motor. Targets are authored against this file's
    # `Drivetrain` root and translate onto the referencing rover.
    #
    # The joints DELIBERATELY omit `physics:localPos0`/`localPos1`: each wheel's
    # placement is the rover's own `Wheel_*.xformOp:translate`, and the avian joint
    # reader DERIVES the anchor from that (body1's origin in body0's frame, anchor on
    # body1 = origin) — so the position is authored once, not typed twice and left to
    # drift. Author a `localPos0` on a joint to override the derivation.
    def PhysicsRevoluteJoint "Wheel_FL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </Drivetrain>
        rel physics:body1 = </Drivetrain/Wheel_FL>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }
    def PhysicsRevoluteJoint "Wheel_FR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </Drivetrain>
        rel physics:body1 = </Drivetrain/Wheel_FR>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }
    def PhysicsRevoluteJoint "Wheel_RL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </Drivetrain>
        rel physics:body1 = </Drivetrain/Wheel_RL>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }
    def PhysicsRevoluteJoint "Wheel_RR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </Drivetrain>
        rel physics:body1 = </Drivetrain/Wheel_RR>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }
}
