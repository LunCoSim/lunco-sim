        double3 xformOp:scale = (12, 0.65, 0.25)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        bool physics:collisionEnabled = true
    }

    def Cylinder "RoundLow01" (prepend references = </RockerBogieArticulationCourse/Round05cm>) { double3 xformOp:translate = (0, 0.025, 28); uniform token[] xformOpOrder = ["xformOp:translate"] }
    def Cylinder "RoundLow02" (prepend references = </RockerBogieArticulationCourse/Round05cm>) { double3 xformOp:translate = (0, 0.025, 26.9); uniform token[] xformOpOrder = ["xformOp:translate"] }
