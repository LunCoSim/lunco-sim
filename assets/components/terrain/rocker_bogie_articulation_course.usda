#usda 1.0
(
    defaultPrim = "RockerBogieArticulationCourse"
    upAxis = "Y"
    metersPerUnit = 1
)

# One composed, lane-wide course: five identical rounded ridges at each height,
# then five identical rectangular ridges, followed by a continuous grade ladder.
def Xform "RockerBogieArticulationCourse" (kind = "component")
{
    class Cylinder "Round05cm" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        uniform token axis = "X"
        double radius = 0.025
        double height = 10
        bool physics:collisionEnabled = true
    }
    class Cylinder "Round15cm" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        uniform token axis = "X"
        double radius = 0.075
        double height = 10
        bool physics:collisionEnabled = true
    }
    class Cylinder "Round25cm" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        uniform token axis = "X"
        double radius = 0.125
        double height = 10
        bool physics:collisionEnabled = true
    }
    class Cube "Square05cm" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        double size = 1
