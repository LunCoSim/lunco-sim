    def Mesh "ContinuousGrade" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        int[] faceVertexCounts = [4,4,4,4,4,4,4,4,4,4]
        int[] faceVertexIndices = [0,1,3,2, 2,3,5,4, 4,5,7,6, 6,7,9,8, 8,9,11,10, 10,11,13,12, 12,13,15,14, 14,15,17,16, 16,17,19,18, 18,19,21,20]
        point3f[] points = [(-5,0.01,-10),(5,0.01,-10),(-5,0.01,-13),(5,0.01,-13),(-5,0.2725,-16),(5,0.2725,-16),(-5,0.8015,-19),(5,0.8015,-19),(-5,1.6053,-22),(5,1.6053,-22),(-5,2.6972,-25),(5,2.6972,-25),(-5,4.0961,-28),(5,4.0961,-28),(-5,5.8282,-31),(5,5.8282,-31),(-5,7.9288,-34),(5,7.9288,-34),(-5,10.4461,-37),(5,10.4461,-37),(-5,0.01,-49.437),(5,0.01,-49.437)]
