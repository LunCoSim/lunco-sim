    def Cube "Ramp35Deg" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        double size = 1.0
        double3 xformOp:translate = (0, 33.887, -82.94)
        double3 xformOp:scale = (10.0, 0.25, 8.0)
        double3 xformOp:rotateXYZ = (-35, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        bool physics:collisionEnabled = true
    }
    def Cube "Ramp40Deg" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        double size = 1.0
        double3 xformOp:translate = (0, 43.618, -95.62)
        double3 xformOp:scale = (10.0, 0.25, 8.0)
        double3 xformOp:rotateXYZ = (-40, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
