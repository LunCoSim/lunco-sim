#usda 1.0
(
    defaultPrim = "DescentLander"
    upAxis = "Y"
    metersPerUnit = 1
)

# A powered-descent lander AIRFRAME — engine, tanks, legs, sensors, avionics. It flies
# what it is told and nothing else: possess it and the stick flies it; spawn it and it
# sits, because nothing is commanding it.
#
# It has no autopilot. Guidance is a component a SCENE composes onto it:
#
#   def "Lander" (
#       prepend references = [
#           @lunco://vessels/landers/descent_lander.usda@</DescentLander>,
#           @lunco://components/gnc/descent_guidance.usda@</DescentGuidance>,
#       ]
#   )
#   { double3 xformOp:translate = (0, 60.0, 0) }
#
# The airframe's flight-control system is APPLIED here (`LunCoProgramAPI`), not bolted
# on, because it is not separable: its `inputs:` ARE the vessel's control surface — the
# ports the control profile writes when a session takes the stick. A lander without it
# is not a lander without an autopilot; it is a lander without an engine.
#
#   possession  ──(piloted)───► Lander.mo  authority gate
#   session stick ──────────────► pitch/roll/yaw/external_throttle
#   guidance program (if any) ──► guidance_throttle   ◄── UNWIRED = 0 = does not fly itself
#   Avian body ──(quat, mass, inertia)──► Lander.mo
#                                    │  force/torque (world frame)
#                                    ▼
#                              Avian body
#
# Gravity is applied by lunco-environment; the model must NOT re-apply it. Thrust is
# body-frame, so the engine fires along the lander's own +Y and follows attitude.
#
# Controls (once possessed — see `../control_profiles.usda@</LanderControls>`):
#   Space       — full thrust
#   W/S/A/D     — pitch/roll torque
#   Q/E         — yaw torque
#   Backspace   — release possession

def Xform "DescentLander" (
    doc = "A powered-descent lander. Possess it to take the stick: Space thrusts, WASD tilts, Q/E turns. It has no guidance of its own — a scene composes that on."
    # An ASSEMBLY: a model built out of other models — its altimeter, its IMU, its
    # control profile all arrive by reference. USD's rule is that a `component` may not
    # contain component models, and the kind is what tells a browser (and the UI)
    # whether a prim is a thing you open up or a thing you place.
    kind = "assembly"
    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI", "LunCoCatalogAPI", "LunCoVesselAPI", "LunCoProgramAPI"]
)
{
    # Emission REQUIRES a material. `displayColor` / `displayOpacity` are real
    # UsdGeomGprim primvars and stay on the geometry, but USD has no "display
    # emissive" — so every glow here is a UsdPreviewSurface `inputs:emissiveColor`
    # on a bound Shader.
    #
    # The emissives are HDR (>1) on purpose: base colour stays dark and the GLOW
    # carries the colour, so the Sun cannot wash the flame to tan.
    def Scope "Looks"
    {
        def Material "Nozzle_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/Nozzle_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.14, 0.14, 0.16)
                color3f inputs:emissiveColor = (0.5, 0.18, 0.03)
                token outputs:surface
            }
        }

        # PLUME CHEMISTRY — LOX/RP-1 (kerosene). The two emissives below say so:
        # a yellow-white core, `FlameCore_Mat` (6.0, 3.5, 0.9), inside an orange
        # shroud, `Flame_Mat` (3.0, 1.0, 0.12). That is the signature of a SOOTY,
        # carbon-rich hydrocarbon flame — incandescent carbon particulate
        # radiating as a roughly 2300 K grey body. Hypergolics (Aerozine-50/N2O4,
        # as on the Apollo LM) and LOX/LH2 both burn far cleaner and nearly
        # invisibly, and would want a pale blue at a small fraction of this
        # radiance.
        #
        # These values are load-bearing beyond the shader: `scenarios/flame.rhai`
        # READS `FlameCore_Mat`'s `inputs:emissiveColor` back through the standard
        # UsdShade chain and derives the plume light's colour and brightness from
        # it, so this is the one place the plume's radiance is stated. Switch the
        # engine to hydrogen here and the light that falls on the regolith changes
        # with it — there is no second constant to remember.
        def Material "Flame_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/Flame_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.5, 0.16, 0.02)
                color3f inputs:emissiveColor = (3.0, 1.0, 0.12)
                token outputs:surface
            }
        }

        def Material "FlameCore_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/FlameCore_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.95, 0.7, 0.2)
                color3f inputs:emissiveColor = (6.0, 3.5, 0.9)
                token outputs:surface
            }
        }

        # Landing-strut load glow. The COLOUR of a strut under load is authored
        # HERE — the actuator (`scenarios/leg_spring.rhai`) reads this emissive
        # through the standard material:binding chain (exactly as `flame.rhai`
        # reads its cone's), takes it as the chroma at `load_ref`, and writes
        # it back scaled by the strut model's live `load` output each tick. So:
        # Modelica publishes the force, USD declares the shader and the wire,
        # rhai only plumbs. Retint this material and the landing glow follows;
        # no script edit.
        def Material "StrutGlow_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/StrutGlow_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.4, 0.42, 0.46)
                # The glow at NOMINAL load — instrument GREEN, "the structure
                # is working and happy". The actuator grades this toward the
                # overload red authored in its `hot_r/g/b` params as the strut
                # model's live `load` climbs past `load_ref`: green = good,
                # red = heavily compressed. Both endpoints are authored data —
                # retint either and the landing reads differently, no script
                # edit.
                color3f inputs:emissiveColor = (0.4, 3.4, 0.9)
                token outputs:surface
            }
        }

        # MLI blanket — the gold crinkled foil, from the engine's shader
        # library (`lunco://shaders/mli_foil.wgsl`). Procedural facet noise:
        # each foil patch leans its own way and catches the sun in patches,
        # which is what makes a hull read as insulation blanket instead of
        # painted metal. `v_scale` matches the hull's circumference/height
        # ratio so the crinkle cells stay square on the barrel.
        def Material "MliFoil_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/MliFoil_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:wgsl:sourceAsset = @lunco://shaders/mli_foil.wgsl@
                color3f inputs:foil_color = (0.83, 0.62, 0.18)
                color3f inputs:shade_color = (0.45, 0.30, 0.08)
                float inputs:crinkle = 26.0
                float inputs:facet_depth = 0.55
                float inputs:sheen = 0.85
                float inputs:v_scale = 0.19
                token outputs:surface
            }
        }

        # The deployed arrays' photovoltaic surface — a WGSL shader, named for the
        # `wgsl` render context exactly as the surfaces above are named for
        # `UsdPreviewSurface`. Both wings wear it: same cells, same cut.
        def Material "SolarWing_Mat"
        {
            token outputs:surface.connect = </DescentLander/Looks/SolarWing_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:wgsl:sourceAsset = @lunco://shaders/solar_panel.wgsl@
                float inputs:v_scale = 1.7
                float inputs:cell_rows = 8.0
                float inputs:cell_cols = 14.0
                float inputs:cell_gap = 0.01
                float inputs:bus_width = 0.004
                float inputs:border = 0.05
                color3f inputs:cell_color = (0.04, 0.05, 0.28)
                color3f inputs:bus_color = (0.9, 0.9, 0.95)
                color3f inputs:frame_color = (0.15, 0.15, 0.18)
                token outputs:surface
            }
        }
    }

    # A palette item: an airframe with no guidance does nothing surprising when it
    # lands in a scene — it falls, and it waits to be flown.
    uniform bool lunco:spawnable = true
    uniform bool lunco:vessel = true

    bool physics:rigidBodyEnabled = true
    float physics:mass = 2000.0

    # Principal inertia, in the body frame, for the 2000 kg vehicle above.
    #
    # This MUST be authored whenever `physics:mass` is. Authoring mass alone
    # overrides the mass and NOTHING else: Avian keeps the angular inertia it
    # derived from the collider geometry at default density, which for this hull
    # is a ~69 kg body. The vehicle then had a lander's mass and a toolbox's
    # rotational inertia — measured `inertia_xx` was 159 kg m^2 against the 4625
    # the geometry implies, i.e. ~29x too easy to spin. Every disturbance torque
    # (and the weld to the rover is a large one, acting through a 1.5 m lever)
    # produced ~29x the angular acceleration it should, which is what threw the
    # stack to 25 rad/s within half a second of the descent starting. No
    # stabiliser with sane authority can hold a vehicle whose inertia is a
    # thirtieth of its geometry.
    #
    # Values are the solid cylinder of the `Hull` collider (r = 2.5, h = 3.0):
    #   I_xx = I_zz = m*(3r^2 + h^2)/12 = 2000*(18.75 + 9)/12 = 4625
    #   I_yy        = m*r^2/2           = 2000*3.125          = 6250
    # I_xx = I_zz because the hull is axisymmetric about +Y — the runtime's
    # 159/229 asymmetry was itself a sign the tensor did not come from this mass.
    float3 physics:diagonalInertia = (4625.0, 6250.0, 4625.0)

    # Vacuum: no aerodynamic drag. Linear damping is a tiny numerical settle only;
    # there is deliberately NO angular damping — angular momentum is conserved, so
    # a spin persists until a torque stops it. Arresting rotation is the job of the
    # reaction-control system (RCS), to be added as a Modelica/rhai attitude-hold
    # script that reads `angvel_*` and commands counter-`torque_*`. Until then the
    # lander keeps whatever spin the pilot gives it — as a real one would.
    float physxRigidBody:linearDamping = 0.02

    # ── Flight control system (the airframe's own avionics) ──────────────────
    # The control LAW a pilot flies through: it turns a command into world force and
    # torque and burns propellant for it. No altitude, no setpoint, no descent law —
    # see `models/Lander.mo`. Its `inputs:` are the vessel's control surface: the
    # control profile writes `external_throttle` / `pitch` / `roll` / `yaw` into them
    # when a session possesses this prim.
    uniform asset lunco:program:sourceAsset = @lunco://models/Lander.mo@

    # It drives thrust every solver step on a body the client predicts, so it must
    # promise it steps fast enough to be trusted with a force.
    uniform bool lunco:program:realtimeSafe = true

    # Co-sim wiring — native USD `connectionPaths`. A self-loop on this prim: the
    # model's outputs are the body's force inputs, and the body's state is the model's
    # inputs.
    float inputs:force_x.connect = </DescentLander.outputs:force_x>
    float inputs:force_y.connect = </DescentLander.outputs:force_y>
    float inputs:force_z.connect = </DescentLander.outputs:force_z>
    float inputs:torque_x.connect = </DescentLander.outputs:torque_x>
    float inputs:torque_y.connect = </DescentLander.outputs:torque_y>
    float inputs:torque_z.connect = </DescentLander.outputs:torque_z>
    float inputs:q_w.connect = </DescentLander.outputs:quat_w>
    float inputs:q_x.connect = </DescentLander.outputs:quat_x>
    float inputs:q_y.connect = </DescentLander.outputs:quat_y>
    float inputs:q_z.connect = </DescentLander.outputs:quat_z>
    float inputs:inertia_xx.connect = </DescentLander.outputs:inertia_xx>
    float inputs:inertia_yy.connect = </DescentLander.outputs:inertia_yy>
    float inputs:inertia_zz.connect = </DescentLander.outputs:inertia_zz>
    float inputs:piloted.connect = </DescentLander.outputs:piloted>
    float inputs:throttle.connect = </DescentLander.outputs:throttle>

    # Angular rate feedback for the attitude stabiliser below. State in, torque out —
    # the same self-loop shape as the quaternion wires above.
    float inputs:omega_x.connect = </DescentLander.outputs:angvel_x>
    float inputs:omega_y.connect = </DescentLander.outputs:angvel_y>
    float inputs:omega_z.connect = </DescentLander.outputs:angvel_z>

    # `guidance_throttle` and the `guidance_pitch/roll/yaw` attitude wires are
    # deliberately NOT connected. Unwired, they are 0, and the lander commands nothing
    # of its own. A scene that wants it to fly itself composes
    # `components/gnc/descent_guidance.usda`, which authors the wires.

    # A parameter is an input with a constant instead of a connection.
    # Attitude authority = angular ACCELERATION (rad/s^2) per unit stick. With no
    # damping this is a pure α: hold the stick and the rate ramps; release and the
    # rate holds (momentum conserved — an RCS script stops it later). Kept low so a
    # tap is a gentle nudge, not a violent tumble.
    float inputs:ang_authority = 0.6

    # RCS stability augmentation ON. A powered-descent lander has attitude control
    # thrusters; a vehicle that cannot hold its own attitude is not a lander, it is a
    # brick with an engine. Concretely: without this, any tilt is permanent, and since
    # thrust points along body +Y the vehicle then flies its own tilt — one bad spawn
    # transient is unrecoverable and the descent diverges.
    #
    # This is the VEHICLE's stabiliser, so it holds whoever is commanding — pilot,
    # guidance program, or nobody. It only holds attitude; it never touches throttle,
    # so it cannot land anything by itself and does not make the vehicle a mission.
    # A scene that wants the raw unaugmented airframe overrides this to 0.
    float inputs:attitude_hold = 1.0

    # ── Propellant events ────────────────────────────────────────────────────
    # A threshold crossing on a model output, published as an event the supervisory
    # script (and anything else) reacts to. One prim per rule: the port, the
    # comparison, the threshold and the name are each a typed property.
    def LunCoPortEvent "LowFuel"
    {
        uniform token lunco:event:port = "m_prop"
        uniform token lunco:event:op = "lt"
        double lunco:event:threshold = 200.0
        uniform token lunco:event:emit = "lander_low_fuel"
    }
    def LunCoPortEvent "Depleted"
    {
        uniform token lunco:event:port = "m_prop"
        uniform token lunco:event:op = "le"
        double lunco:event:threshold = 0.5
        uniform token lunco:event:emit = "lander_depleted"
    }

    # ── Onboard supervisor ───────────────────────────────────────────────────
    # Watches for touchdown and reacts to the propellant events above. It does NOT
    # fly the descent — mission orchestration is a separate concern and lives on a
    # scene's own `Scenario` prim. A program prim, so it can be deleted, replaced, or
    # referenced in without touching the airframe.
    def LunCoProgram "Subsystems" (
        doc = "Touchdown latch and propellant-event notices. Does not fly the vehicle."
    )
    {
        uniform asset lunco:program:sourceAsset = @lunco://scenarios/lander_subsystems.rhai@
    }

    # Intent->port control: shared lander profile as a child `references` arc
    # (forward/back->pitch, left/right->roll, yaw_left/right->yaw, action->throttle).
    # Composes through a spawn/reference like a component.
    def "Controls" (
        prepend references = @lunco://vessels/control_profiles.usda@</LanderControls>
    )
    {
    }

    # ── Physics + visible hull ───────────────────────────────────────────────
    # The body's mass and shape. The root is an `Xform` — a vehicle, not a cylinder —
    # so the hull is an ordinary child gprim that both renders and collides, and the
    # compound body is hull + 4 footpads. Gold multi-layer-insulation (MLI) foil: a
    # warm metallic `displayColor`, not wrapped in solar cells. The array lives on the
    # deployed side wings, so the body reads as a spacecraft hull, not a battery barrel.
    def Cylinder "Hull" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        uniform token axis = "Y"
        double radius = 2.5
        double height = 3.0
        color3f[] primvars:displayColor = [(0.78, 0.62, 0.27)]
        bool physics:collisionEnabled = true
    }

    # ── Onboard sensors (reusable library primitives, referenced) ──
    # Altimeter: downward range-finder → `range` port. The airframe carries the SENSOR;
    # what reads it is somebody else's business (the guidance component wires it).
    # Mounted at the nozzle bottom, casting -Y.
    def "Altimeter" (
        prepend references = @lunco://vessels/sensors/altimeter.usda@</Altimeter>
    )
    {
        double3 xformOp:translate = (0.0, -3.3, 0.0) # nozzle bottom
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # IMU: 9-DOF attitude + accel source. Mounted at the body centre of mass.
    def "IMU" (
        prepend references = @lunco://vessels/sensors/imu.usda@</Imu>
    )
    {
        double3 xformOp:translate = (0.0, 0.0, 0.0) # at CoM
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # ── Visual-only structure ──

    # Upper deck (flat top with instruments)
    def Cylinder "UpperDeck"
    {
        uniform token axis = "Y"
        double radius = 2.6
        double height = 0.15
        double3 xformOp:translate = (0, 1.55, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.6, 0.58, 0.55)]
        bool physics:collisionEnabled = false
    }

    # ── High-gain antenna: a REAL parabolic dish, not a sphere placeholder ──
    # The airframe carries exactly ONE comms structure. A mast, a spike and a
    # sphere "dish" each lived here at some point and are gone rather than
    # deactivated: a library asset that ships switched-off geometry makes every
    # consumer read three prims to learn which one is real.
    # The reflector is a rational NurbsPatch: u is an EXACT circle (9 CVs, the
    # classic 4-arc rational form — √2/2 weights on the diagonal CVs and doubled
    # interior knots), v a cubic parabola profile y = r²/4f, f = 0.35 m. This is
    # the "lathe" spelling the engine's NURBS reader exists for; the sampled
    # surface is a true paraboloid, which a scaled Sphere never was.
    # Deactivated by director's call (2026-07-20): with the yaw spin added to
    # the exposition beats the dish reads as clutter on camera, and the comms
    # story is carried by the mast + spike. The NURBS reflector stays authored
    # — it is the parametric-antenna base for the Earth-tracking gimbal work —
    # flip active when that lands.
    # ACTIVE and mounted ON TOP of the mast, scaled ×2.6 → ~3 m across: a
    # high-gain dish the audience can actually SEE at video size and read as
    # comms hardware. (Authored at 0.58 m radius for the parametric work; the
    # scale is the film's call, the geometry stays the real paraboloid.)
    def Xform "HighGainDish"
    {
        # Sits straight on the upper deck now the mast is gone (deck top is
        # y≈1.63; the dish's own boom carries the rest).
        double3 xformOp:translate = (0.0, 2.05, 0.0)
        # Face the dish up-and-outboard, like a parked high-gain waiting for
        # Earth: boresight ~35° off vertical toward +X.
        double3 xformOp:rotateXYZ = (0.0, 0.0, -35.0)
        double3 xformOp:scale = (2.6, 2.6, 2.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]

        def NurbsPatch "Reflector"
        {
            int uVertexCount = 9
            int vVertexCount = 4
            int uOrder = 3
            int vOrder = 3
            double[] uKnots = [0, 0, 0, 0.25, 0.25, 0.5, 0.5, 0.75, 0.75, 1, 1, 1]
            # vKnots unauthored → reader defaults to clamped, which is what a
            # profile curve wants.
            double[] pointWeights = [
                1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1,
                1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1,
                1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1,
                1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1, 0.70710678, 1]
            # 4 profile rings (r, y): (0.02, 0) (0.20, 0.03) (0.40, 0.11) (0.58, 0.24),
            # u varying fastest; corner CVs sit at (±r, y, ±r) per the rational form.
            point3f[] points = [
                (0.02, 0, 0), (0.02, 0, 0.02), (0, 0, 0.02), (-0.02, 0, 0.02), (-0.02, 0, 0), (-0.02, 0, -0.02), (0, 0, -0.02), (0.02, 0, -0.02), (0.02, 0, 0),
                (0.20, 0.03, 0), (0.20, 0.03, 0.20), (0, 0.03, 0.20), (-0.20, 0.03, 0.20), (-0.20, 0.03, 0), (-0.20, 0.03, -0.20), (0, 0.03, -0.20), (0.20, 0.03, -0.20), (0.20, 0.03, 0),
                (0.40, 0.11, 0), (0.40, 0.11, 0.40), (0, 0.11, 0.40), (-0.40, 0.11, 0.40), (-0.40, 0.11, 0), (-0.40, 0.11, -0.40), (0, 0.11, -0.40), (0.40, 0.11, -0.40), (0.40, 0.11, 0),
                (0.58, 0.24, 0), (0.58, 0.24, 0.58), (0, 0.24, 0.58), (-0.58, 0.24, 0.58), (-0.58, 0.24, 0), (-0.58, 0.24, -0.58), (0, 0.24, -0.58), (0.58, 0.24, -0.58), (0.58, 0.24, 0)]
            color3f[] primvars:displayColor = [(0.92, 0.92, 0.95)]
            bool physics:collisionEnabled = false
        }

        # Feed arm: a NURBS curve swept into a TUBE by its authored `widths` —
        # rim to focus (f = 0.35 above the apex) in one smooth cubic.
        def NurbsCurves "FeedArm"
        {
            int[] curveVertexCounts = [4]
            int[] order = [4]
            double[] knots = [0, 0, 0, 0, 1, 1, 1, 1]
            point3f[] points = [(0.56, 0.25, 0), (0.44, 0.44, 0), (0.16, 0.47, 0), (0.0, 0.38, 0)]
            float[] widths = [0.03]
            color3f[] primvars:displayColor = [(0.75, 0.75, 0.78)]
            bool physics:collisionEnabled = false
        }

        # The feed horn at the focus, looking back into the reflector.
        def Cylinder "FeedHorn"
        {
            uniform token axis = "Y"
            double radius = 0.045
            double height = 0.09
            double3 xformOp:translate = (0.0, 0.36, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.3, 0.3, 0.34)]
            bool physics:collisionEnabled = false
        }

        # Mounting boom, dish back down to the deck edge.
        def Cylinder "Boom"
        {
            uniform token axis = "Y"
            double radius = 0.05
            double height = 0.7
            double3 xformOp:translate = (0.0, -0.38, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.55, 0.55, 0.58)]
            bool physics:collisionEnabled = false
        }
    }

    # Engine bell — flares WIDE at the exit (bottom), narrowing to the throat (top).
    # Bevy renders an axis-Y cone apex-down, so the 180° flip puts the wide mouth at
    # the bottom. Dark metallic with a hot emissive throat.
    def Cone "Nozzle"
    {
        uniform token axis = "Y"
        double radius = 1.35
        double height = 1.9
        double3 xformOp:translate = (0, -2.6, 0)
        double3 xformOp:rotateXYZ = (180.0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
        rel material:binding = </DescentLander/Looks/Nozzle_Mat>
        bool physics:collisionEnabled = false
    }

    # Engine exhaust plume — TWO translucent emissive cones (apex DOWN, below the
    # nozzle), each DESCRIBED IN rhai, not built-in Rust: the script reads the FCS
    # `throttle` signal each tick, scales the cone to match (collapsing to ~zero at
    # idle), and adds a smoothed flicker. One reusable script drives both cones; each
    # cone's numbers are its own program's typed parameters. The outer cone is a soft
    # orange halo; the inner "...Core" is a slimmer, hotter yellow-white tongue.
    def Cone "Flame"
    {
        uniform token axis = "Y"
        double radius = 1.0
        double height = 1.0
        double3 xformOp:translate = (0, -3.5, 0)
        double3 xformOp:rotateXYZ = (180.0, 0, 0)
        double3 xformOp:scale = (0.02, 0.02, 0.02)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        rel material:binding = </DescentLander/Looks/Flame_Mat>
        float[] primvars:displayOpacity = [0.4]
        bool physics:collisionEnabled = false
        # Exhaust is light being EMITTED, not matter blocking it. Translucency alone
        # does not say this: a blended surface still rasterises opaquely into the
        # shadow map, so the plume threw a hard shadow on the terrain below.
        # Omniverse's name (Composer's "Cast Shadows" toggle), so this reads the same
        # in RTX as it does here.
        bool primvars:doNotCastShadows = true

        def LunCoProgram "Plume"
        {
            uniform asset lunco:program:sourceAsset = @lunco://scenarios/flame.rhai@
            custom float lunco:param:wmax = 1.05
            custom float lunco:param:lmax = 3.6
            custom float lunco:param:flick = 1.0
        }
    }
    def Cone "FlameCore"
    {
        uniform token axis = "Y"
        double radius = 1.0
        double height = 1.0
        double3 xformOp:translate = (0, -3.4, 0)
        double3 xformOp:rotateXYZ = (180.0, 0, 0)
        double3 xformOp:scale = (0.02, 0.02, 0.02)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        rel material:binding = </DescentLander/Looks/FlameCore_Mat>
        float[] primvars:displayOpacity = [0.85]
        bool physics:collisionEnabled = false
        bool primvars:doNotCastShadows = true

        def LunCoProgram "Plume"
        {
            uniform asset lunco:program:sourceAsset = @lunco://scenarios/flame.rhai@
            custom float lunco:param:wmax = 0.5
            custom float lunco:param:lmax = 2.5
            custom float lunco:param:flick = 0.5
            # The light half of the same program. `exitance` is lm/m^2 per unit
            # emissive radiance — the ONE authored photometric constant; the
            # colour and the brightness scale are both READ from this cone's
            # bound `FlameCore_Mat` emissive, so retinting the flame retints and
            # rebalances its light automatically. `lightflick` is the light's
            # flicker depth (shallower than the mesh's, and one tick behind it).
            custom float lunco:param:exitance = 44200
            custom float lunco:param:rmax = 0.6
            custom float lunco:param:lightflick = 0.35
        }

        # The plume as a LIGHT SOURCE — a CHILD of the cone it is the light of.
        #
        # Emissive geometry in a forward renderer illuminates nothing. During a
        # descent burn that left the regolith directly beneath the vehicle — and
        # the vehicle's own underside — lit only by the sun, so a 60 kN engine
        # firing metres above the ground made no difference to the ground. On an
        # airless body, with hard shadows and no atmospheric scatter to hide the
        # error, that is the most obviously wrong thing in frame.
        #
        # WHY IT LIVES HERE, INSIDE THE CONE, WITH NO PROGRAM OF ITS OWN
        # It used to be a sibling with its own script and its own copy of the
        # throttle walk, flicker state and brightness constant. Parenting it to
        # the cone makes "plume visible <=> light on" structural instead of an
        # invariant two files maintain: it is destroyed with the cone, hidden with
        # the cone (Bevy inherited visibility), and — authored at the cone's LOCAL
        # ORIGIN — it rides the plume centroid the program already positions each
        # tick, while being immune to the parent's animated non-uniform scale and
        # 180-degree flip. A child at the origin has no transform to keep in sync.
        #
        # `SphereLight` (deliberately WITHOUT `UsdLuxShapingAPI` — authoring cone
        # attrs would make it a SpotLight instead) loads as a Bevy `PointLight`.
        #
        # Intensity and colour are not authored as VALUES here: the program
        # derives both each tick from this cone's bound `UsdPreviewSurface`
        # emissive, read through the standard `material:binding` -> `Material`
        # -> `outputs:surface.connect` -> `Shader` -> `inputs:emissiveColor`
        # chain. Nothing below is a tuned brightness.
        #
        # `inputs:intensity = 0` IS authored, and is an initial STATE rather than
        # a value: a scene that loads paused never runs the program, so an
        # unauthored (default non-zero) intensity would flash a full-brightness
        # plume before the first tick. Zero is the only safe starting point.
        #
        # Shadows are left OFF (the loader's default for local lights): a
        # shadow-casting point light re-renders the scene into a cubemap every
        # frame, and this one sits inside the plume pointing at open ground with
        # nothing meaningful to occlude.
        def SphereLight "PlumeLight" (
            prepend apiSchemas = ["LunCoLightAPI"]
        )
        {
            float inputs:intensity = 0
            float inputs:radius = 0.06
            # Schema-declared (LunCoLightAPI), so no `custom` — that qualifier is
            # for attributes no schema defines.
            float lunco:light:range = 25.0
        }
    }

    # Side tanks (fuel/oxidizer — 4 tanks at 90° intervals)
    def Capsule "TankPX"
    {
        uniform token axis = "Y"
        double radius = 0.4
        double height = 2.4
        double3 xformOp:translate = (2.2, 0.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.75, 0.72, 0.65)]
        bool physics:collisionEnabled = false
    }
    def Capsule "TankNX"
    {
        uniform token axis = "Y"
        double radius = 0.4
        double height = 2.4
        double3 xformOp:translate = (-2.2, 0.0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.75, 0.72, 0.65)]
        bool physics:collisionEnabled = false
    }
    def Capsule "TankPZ"
    {
        uniform token axis = "Y"
        double radius = 0.4
        double height = 2.4
        double3 xformOp:translate = (0, 0.0, 2.2)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.75, 0.72, 0.65)]
        bool physics:collisionEnabled = false
    }
    def Capsule "TankNZ"
    {
        uniform token axis = "Y"
        double radius = 0.4
        double height = 2.4
        double3 xformOp:translate = (0, 0.0, -2.2)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.75, 0.72, 0.65)]
        bool physics:collisionEnabled = false
    }

    # ── Deployed solar arrays — the "panels on the sides" ──────────────────
    # Flat cells-up wings on ±X, tilted toward the sun. Thin slabs, but they are
    # solid: `collisionEnabled` folds each into the compound (like the pads below)
    # so a rover cannot drive through a deployed array.
    # Each wing is TWO slabs: a structural backsheet (dark, both faces plain —
    # this is the collider) and a thin CELLS layer riding 0.045 m above it on
    # the wing's own normal, wearing the photovoltaic shader. Real arrays have
    # cells on the sun side only; the old single slab shaded cells onto the
    # underside too. The cells slab is inset (5.45 × 3.25 vs 5.6 × 3.4) so the
    # backsheet shows as a frame border around the array.
    def Cube "SolarWingPX"
    {
        double size = 1.0
        double3 xformOp:translate = (5.4, 1.4, 0)
        double3 xformOp:rotateXYZ = (0, 0, -12.0)
        double3 xformOp:scale = (5.6, 0.06, 3.4)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.16, 0.16, 0.19)]
        bool physics:collisionEnabled = true
    }
    def Cube "SolarCellsPX"
    {
        double size = 1.0
        # Wing normal is Rz(-12°)·(0,1,0) = (0.2079, 0.978, 0); offset 0.045 m.
        double3 xformOp:translate = (5.409, 1.444, 0)
        double3 xformOp:rotateXYZ = (0, 0, -12.0)
        double3 xformOp:scale = (5.45, 0.02, 3.25)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.06, 0.06, 0.22)]
        rel material:binding = </DescentLander/Looks/SolarWing_Mat>
        bool physics:collisionEnabled = false
    }
    def Cube "SolarWingNX"
    {
        double size = 1.0
        double3 xformOp:translate = (-5.4, 1.4, 0)
        double3 xformOp:rotateXYZ = (0, 0, 12.0)
        double3 xformOp:scale = (5.6, 0.06, 3.4)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.16, 0.16, 0.19)]
        bool physics:collisionEnabled = true
    }
    def Cube "SolarCellsNX"
    {
        double size = 1.0
        double3 xformOp:translate = (-5.409, 1.444, 0)
        double3 xformOp:rotateXYZ = (0, 0, 12.0)
        double3 xformOp:scale = (5.45, 0.02, 3.25)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.06, 0.06, 0.22)]
        rel material:binding = </DescentLander/Looks/SolarWing_Mat>
        bool physics:collisionEnabled = false
    }

    # ── Wing yokes — the wings visibly HANG from something ─────────────────
    # A boom from the hull side to each wing root, in the wing's own 12° plane,
    # plus a hinge block at the hull end. Pure display (the wings already carry
    # the colliders); what these buy is the eye no longer reading the arrays as
    # floating props.
    def Cylinder "WingYokePX"
    {
        uniform token axis = "X"
        double radius = 0.09
        double height = 1.9
        double3 xformOp:translate = (3.15, 1.65, 0.0)
        double3 xformOp:rotateXYZ = (0, 0, -12.0)
