            double3 xformOp:rotateXYZ = (0.0, 90.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            prepend rel lunco:motor:drivenWheel = </RockerBogie/RockerR/Wheel_FR>
            float inputs:demand.connect = </RockerBogie.outputs:drive_right>
            # 12.9 km/h measured — see Motor_FL. All six must
            # agree, or the fast wheels drag the slow ones and every wheel scrubs.
            float lunco:motor:noLoadSpeed = 14400.0
        }

