            double3 xformOp:translate = (-0.1, -0.2, 0.6)
            double3 xformOp:rotateXYZ = (0.0, 90.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            prepend rel lunco:motor:drivenWheel = </RockerBogie/BogieR/Wheel_RR>
            float inputs:demand.connect = </RockerBogie.outputs:drive_right>
            float lunco:motor:noLoadSpeed = 14400.0   # 12.9 km/h — see Motor_FL
        }

        def Xform "Gearbox_RR" (
            prepend references = @lunco://components/mobility/gearbox.usda@</Gearbox>
        )
        {
            double3 xformOp:translate = (0.055, -0.2, 0.6)
            double3 xformOp:rotateXYZ = (0.0, 90.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            float inputs:torque.connect = </RockerBogie/BogieR/Motor_RR.outputs:torque>
        }
    }

    # All joints below DELIBERATELY omit `physics:localPos0`/`localPos1`: each body's
    # placement is already its `xformOp:translate`, and the avian joint reader DERIVES
    # the anchor from the composed world poses (body1's origin in body0's rotation
    # frame; anchor on body1 = origin). This works for the sibling rocker↔bogie hinges
    # and the scaled hierarchy, so no anchor is typed — or left to drift — twice.
    # Author a `localPos0` on a joint to override the derivation.
    #
    # ── Lateral-axis revolute hinges (chassis ↔ rocker) ─────────────────────
    # HingeL/R: chassis <-> rocker joints.
    # NASA MER/MSL use mechanical stops limiting rocker travel to +/-30 to +/-45 degrees.
    # We use +/-30 degrees to keep the chassis level and prevent differential lockup.
    def PhysicsRevoluteJoint "HingeL" (
        doc = "Chassis-to-rocker hinge. Limited to +/-30 deg to match NASA mechanical stops, preventing excessive chassis roll and differential lockup."
    )
    {
        rel physics:body0 = </RockerBogie>
        rel physics:body1 = </RockerBogie/RockerL>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -30
        float physics:upperLimit = 30
    }
    def PhysicsRevoluteJoint "HingeR" (
        doc = "Chassis-to-rocker hinge. Limited to +/-30 deg to match NASA mechanical stops, preventing excessive chassis roll and differential lockup."
    )
    {
        rel physics:body0 = </RockerBogie>
        rel physics:body1 = </RockerBogie/RockerR>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -30
        float physics:upperLimit = 30
    }

    # ── Differential coupling (rocker-bogie holonomic constraint) ───────────
    # The standard PhysX gear joint over the two chassis↔rocker hinges: it softly
    # couples θ_left + θ_right → restSum (the drive's targetPosition), so the chassis
    # pitch tracks the rocker average instead of flopping on a free pitch DOF. A rigid
    # gear would fight the terrain and chatter, so the compliance is the joint's own
    # angular PhysicsDriveAPI (a strong spring-damper), not an ideal constraint.
    #   stiffness — how strongly the rockers mirror each other
    #   damping   — kills differential oscillation
    #   targetPosition — symmetric rest sum (0 rad)
    #
    # ⚠ SOLVED IMPLICITLY. THIS IS NO LONGER A STABILITY KNOB — BUT IT IS NOT YET
    #   AN IDEAL GEAR EITHER. Read both halves before changing it.
    #
    # `differential_coupling_system` now evaluates the coupling with backward Euler
    # against the constraint's own inverse inertia (`J·M⁻¹·Jᵀ`), so the solved
    # torque is bounded by what the step can absorb. Two things follow, both
    # measured on `scenes/tests/rocker_bogie.usda` (2026-07-22):
    #
    #   · NO STIFFNESS DIVERGES ANY MORE. The old EXPLICIT penalty (`λ = k·c + d·ċ`)
    #     went to NaN inside 10 s at 30 000 and at 60 000. Nothing does now — the
    #     value below is 6× the old NaN threshold and the rig is steady.
    #   · MASS NO LONGER SOFTENS IT. `w` scales the response with the inertia it
    #     acts on. Under the explicit form a 400 kg hull sagged the mirroring to a
    #     29% residual (a FAILING mechanism); it is 8.6% now. At the shipped 300 kg
    #     the residual went 20% → 13.4%, back inside the test's original 15% bound.
    #
    # ⚠ BUT DO NOT SIMPLY CRANK IT. This is still an EXTERNAL torque applied
    # alongside avian's solver, not a constraint solved WITH it, so pushing toward
    # the holonomic limit makes the coupling shove the vehicle around rather than
    # merely couple it: at 1e6 the gear cancels perfectly (L+R = 0.000) and walks
    # the rover clean off the test step by t ≈ 4 s; at 1e8 the rig tumbles (168° of
    # roll). 1e5 is the measured knee — the stiffest setting that still leaves the
    # rover sitting where it was put.
    #
    # A real rocker-bogie differential is a bar or a bevel gearset, with no
    # compliance at all. Reaching that honestly means solving this INSIDE the
    # substep loop with the hinges, as a real constraint. Until then this is a very
    # stiff, mass-independent, unconditionally stable spring — which is a different
    # and much better thing than what it was, but still a spring.
    def PhysxPhysicsGearJoint "Differential" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physxGearJoint:hinge0 = </RockerBogie/HingeL>
        rel physxGearJoint:hinge1 = </RockerBogie/HingeR>
        float physxGearJoint:gearRatio = -1.0
        float drive:angular:physics:targetPosition = 0.0
        float drive:angular:physics:stiffness = 100000.0
        float drive:angular:physics:damping = 5000.0
    }

    # ── Lateral-axis revolute hinges (rocker ↔ bogie) ───────────────────────
    # BogieHingeL/R: rocker <-> bogie joints.
    # NASA rovers limit bogie rotation to +/-20 to +/-30 degrees to prevent the
    # middle/rear wheels from colliding with the rocker frame or chassis belly.
    # We use +/-20 degrees as a safe operating envelope.
    def PhysicsRevoluteJoint "BogieHingeL" (
        doc = "Rocker-to-bogie hinge. Limited to +/-20 deg to match NASA stops, preventing middle/rear wheels from colliding with the rocker frame."
    )
    {
        rel physics:body0 = </RockerBogie/RockerL>
        rel physics:body1 = </RockerBogie/BogieL>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -20
        float physics:upperLimit = 20
    }
    def PhysicsRevoluteJoint "BogieHingeR" (
        doc = "Rocker-to-bogie hinge. Limited to +/-20 deg to match NASA stops, preventing middle/rear wheels from colliding with the rocker frame."
    )
    {
        rel physics:body0 = </RockerBogie/RockerR>
        rel physics:body1 = </RockerBogie/BogieR>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -20
        float physics:upperLimit = 20
    }

    # ── Wheel revolute joints (rocker/bogie ↔ wheel) ────────────────────────
    # The joint is the motor's OUTPUT COUPLING, not the motor: it carries
    # `PhysicsDriveAPI:angular`, the drive `type` and the axis, and NOTHING ELSE.
    # `maxForce` and `targetVelocity` are deliberately absent — the loader writes
    # them from the `Motor_*` / `Gearbox_*` pair that names this joint's WHEEL via
    # `lunco:motor:drivenWheel` — the loader follows wheel → joint to get here — so the
    # torque ceiling is stated once, on the part that makes the torque, instead of being
    # typed here as a second opinion.
    def PhysicsRevoluteJoint "Wheel_FL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/RockerL>
        rel physics:body1 = </RockerBogie/RockerL/Wheel_FL>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_FR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/RockerR>
        rel physics:body1 = </RockerBogie/RockerR/Wheel_FR>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_ML_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieL>
        rel physics:body1 = </RockerBogie/BogieL/Wheel_ML>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_MR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieR>
        rel physics:body1 = </RockerBogie/BogieR/Wheel_MR>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_RL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieL>
        rel physics:body1 = </RockerBogie/BogieL/Wheel_RL>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_RR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieR>
        rel physics:body1 = </RockerBogie/BogieR/Wheel_RR>
        uniform token physics:axis = "X"
        uniform token drive:angular:physics:type = "force"
    }

    # --- Drive law -----------------------------------------------------------
    # HOW throttle/steer become per-side drive is COMPOSITION, not an
    # enumeration. The plain authored state is the instant built-in skid kernel
    # (`PhysxVehicleTankDifferentialAPI` above). For a solver-clocked per-side
    # motor lag, compose on the SAME skid law the other skid rovers use:
    #
    #   def "Rover" (
    #       prepend references = [
    #           @lunco://vessels/rovers/rocker_bogie.usda@</RockerBogie>,
    #           @lunco://components/mobility/drive_laws/modelica_skid.usda@</DriveLaw>,
    #       ]
    #   ) {}
    #
    # The wheels here author no `inputs:drive` connection, so they use the index-parity
    # default (even 0/2/4 = FL/ML/RL ⇒ drive_left, odd 1/3/5 = FR/MR/RR ⇒
    # drive_right) — exactly the port pair the skid law writes.

    # --- Power: does driving cost anything ----------------------------------
    # ORTHOGONAL to the drive law: `infinite` is EMPTY — the absence of a battery
    # is today's drive-forever behavior. `battery` composes the RoverBattery.mo
    # energy budget onto the root: drain follows the commanded drive magnitude,
    # and its `alive` cutoff brownouts the drive ports over the last ~2% of
    # charge — a variant chooses a component, it never restates one.
    #
    # Same two sets `six_wheel_rover.usda` carries, because the difficulty tiers
    # (`variants/rover_*.usda`) sit on THIS chassis now and a tier must not lose a
    # capability by changing suspension.
    variantSet "power" = {
        "infinite" {
        }

        "battery" (
            prepend references = @lunco://components/power/rover_battery.usda@</Power>
        ) {
        }
    }

    # --- Thermal: do the motors have temperatures ---------------------------
    # `none` is EMPTY. `basic` composes the RoverMotorThermal.mo per-side heat
    # balance onto the root: pure telemetry (`temp_left`/`temp_right`, kelvin,
    # readable/watchable ports), nothing acts on it — same choose-a-component
    # shape as `power`.
    variantSet "thermal" = {
        "none" {
        }

        "basic" (
            prepend references = @lunco://components/thermal/motor_thermal.usda@</Thermal>
        ) {
        }
    }
}
