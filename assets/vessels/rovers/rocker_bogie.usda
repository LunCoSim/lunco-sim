        def Cylinder "MiddleAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (0.125, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "RearAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (0.125, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "JointCover"
        {
            uniform token axis = "X"
            double radius = 0.1
            double height = 0.1
            double3 xformOp:translate = (0.0, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.85, 0.7, 0.2)]
            bool physics:collisionEnabled = false
        }

        # Simplified box collider (collision-only, hidden — see RockerL/Collider).
        def Cube "Collider" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
