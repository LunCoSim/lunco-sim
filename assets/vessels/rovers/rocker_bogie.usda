            float physics:mass = 12.0
            double3 xformOp:translate = (0.3, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 3
        }

        # Rear Right Wheel
        def Cylinder "Wheel_RR" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.4
            float physxVehicleWheel:radius = 0.4
            float physics:mass = 12.0
            double3 xformOp:translate = (0.3, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 5
        }

        # Indices 3 and 5, both odd ⇒ `drive_right`. Mirror of the left bogie.
        def Xform "Motor_MR" (
            prepend references = @lunco://components/mobility/motor.usda@</Motor>
        )
        {
            # On the axle, arm between motor and gearbox, turned onto X. See Motor_FL.
            double3 xformOp:translate = (-0.1, -0.2, -0.4)
            double3 xformOp:rotateXYZ = (0.0, 90.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            prepend rel lunco:motor:drivenWheel = </RockerBogie/BogieR/Wheel_MR>
            float inputs:demand.connect = </RockerBogie.outputs:drive_right>
