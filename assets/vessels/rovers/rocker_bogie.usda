        double3 xformOp:translate = (0.9, -0.4, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cylinder "FrontLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.447
            double3 xformOp:translate = (0.0, -0.1, -0.2)
            double3 xformOp:rotateXYZ = (-26.57, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "RearLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.632
            double3 xformOp:translate = (0.0, -0.1, 0.3)
            double3 xformOp:rotateXYZ = (18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
