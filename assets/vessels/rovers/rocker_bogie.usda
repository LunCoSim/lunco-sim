#usda 1.0
(
    defaultPrim = "RockerBogie"
    upAxis = "Y"
    metersPerUnit = 1
)

# G5 — rocker-bogie chassis with a differential coupling.
#
# A complete physical joint-based rocker-bogie suspension with 6 motorized wheels:
#   - Two side rockers (RockerL/R) hinge to the chassis on the X axis.
#   - Two bogies (BogieL/R) hinge to the rear of the rockers on the X axis.
#   - Six wheels (FL/FR/ML/MR/RL/RR) reference the reusable motorized wheel components.
#   - The differential coupling softly enforces: θ_left + θ_right → 0.
#   - Controllable via keyboard/UI through PhysxVehicleTankDifferentialAPI.
#
# FOR PARAMETER EDITING GUIDE: See the accompanying README.md in this directory.

def Xform "RockerBogie" (
    # An ASSEMBLY: a model built out of other models. Its wheels are component models
    # that arrive by reference, and USD forbids a `component` from containing them.
    kind = "assembly"
    prepend apiSchemas = [
        "PhysicsRigidBodyAPI", "PhysxRigidBodyAPI",
        "PhysicsMassAPI",
        "PhysicsArticulationRootAPI",
        "PhysxVehicleContextAPI",
        "PhysxVehicleTankDifferentialAPI", "LunCoCatalogAPI"
    ]
)
{
    uniform bool lunco:spawnable = true
    # Emission REQUIRES a material: USD has no "display emissive" primvar the way
    # it has `displayColor`/`displayOpacity`, so the headlight glow is a
    # UsdPreviewSurface input on a Shader, bound to both lenses.
    def Scope "Looks"
    {
        def Material "Lens_Mat"
        {
            token outputs:surface.connect = </RockerBogie/Looks/Lens_Mat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1.0, 0.95, 0.85)
                # HDR (>1) so the lens reads as a GLOW the sun cannot wash out.
                color3f inputs:emissiveColor = (5.0, 4.75, 4.25)
                token outputs:surface
            }
        }
    }

    # --- VEHICLE MASS & DAMPING ---
    # Edit the chassis mass here (default 300 kg)
    float physics:mass = 300.0
    float lunco:spawnLift = 1.5
    float physxRigidBody:linearDamping = 0.4
    float physxRigidBody:angularDamping = 2.0

    # Intent->port control (stage 2): shared rover profile as a child `references`
    # arc so it composes through a spawn/reference like the wheels.
    def "Controls" (
        prepend references = @lunco://vessels/control_profiles.usda@</RoverControls>
    )
    {
    }

    # --- CHASSIS GEOMETRY & VISUALS ---
    # Gold solar foil main body
    def Cube "Body" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        double size = 1.0
        double3 xformOp:scale = (1.2, 0.4, 1.8)
        uniform token[] xformOpOrder = ["xformOp:scale"]
        color3f[] primvars:displayColor = [(0.85, 0.75, 0.2)]
    }

    # Slanted Solar panel deck on top of the chassis
    def Cube "SolarDeck"
    {
        double size = 1.0
        double3 xformOp:translate = (0.0, 0.21, 0.0)
        double3 xformOp:scale = (1.3, 0.02, 1.9)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.05, 0.05, 0.2)]
        bool physics:collisionEnabled = false
    }

    # High-gain antenna mast and dish
    def Cylinder "AntennaMast"
    {
        uniform token axis = "Y"
        double radius = 0.015
        double height = 0.3
        double3 xformOp:translate = (0.3, 0.35, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
        bool physics:collisionEnabled = false
    }

    def Cylinder "AntennaDish"
    {
        uniform token axis = "Y"
        double radius = 0.15
        double height = 0.02
        double3 xformOp:translate = (0.3, 0.5, 0.6)
        double3 xformOp:rotateXYZ = (30.0, 45.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
        color3f[] primvars:displayColor = [(0.8, 0.8, 0.8)]
        bool physics:collisionEnabled = false
    }

    # Instrument platform / science mast
    def Cylinder "Mast"
    {
        uniform token axis = "Y"
        double radius = 0.04
        double height = 0.8
        double3 xformOp:translate = (0.0, 0.5, -0.6)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
        bool physics:collisionEnabled = false
    }

    def Cube "CameraHead"
    {
        double size = 1.0
        double3 xformOp:scale = (0.2, 0.15, 0.15)
        double3 xformOp:translate = (0.0, 0.95, -0.6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]
        bool physics:collisionEnabled = false
    }

    # Headlights
    def Xform "Headlight_L"
    {
        double3 xformOp:translate = (-0.5, 0.1, -0.9)
        double3 xformOp:rotateXYZ = (-15, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

        def SphereLight "Light"
        (
            prepend apiSchemas = ["ShapingAPI", "ShadowAPI", "LunCoLightAPI"]
        )
        {
            float inputs:intensity = 1000000.0
            float inputs:exposure = 0.0
            color3f inputs:color = (1.0, 0.95, 0.85)
            bool inputs:shadow:enable = true
            float inputs:shaping:cone:angle = 45.0
            float inputs:shaping:cone:softness = 0.3
            float lunco:light:range = 60.0
        }

        def Cylinder "Casing"
        {
            uniform token axis = "Z"
            double radius = 0.1
            double height = 0.15
            double3 xformOp:translate = (0, 0, 0.075)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.1, 0.1, 0.1)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "Lens"
        {
            uniform token axis = "Z"
            double radius = 0.09
            double height = 0.02
            double3 xformOp:translate = (0, 0, -0.01)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            rel material:binding = </RockerBogie/Looks/Lens_Mat>
            bool physics:collisionEnabled = false
        }
    }

    def Xform "Headlight_R"
    {
        double3 xformOp:translate = (0.5, 0.1, -0.9)
        double3 xformOp:rotateXYZ = (-15, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

        def SphereLight "Light"
        (
            prepend apiSchemas = ["ShapingAPI", "ShadowAPI", "LunCoLightAPI"]
        )
        {
            float inputs:intensity = 1000000.0
            float inputs:exposure = 0.0
            color3f inputs:color = (1.0, 0.95, 0.85)
            bool inputs:shadow:enable = true
            float inputs:shaping:cone:angle = 45.0
            float inputs:shaping:cone:softness = 0.3
            float lunco:light:range = 60.0
        }

        def Cylinder "Casing"
        {
            uniform token axis = "Z"
            double radius = 0.1
            double height = 0.15
            double3 xformOp:translate = (0, 0, 0.075)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.1, 0.1, 0.1)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "Lens"
        {
            uniform token axis = "Z"
            double radius = 0.09
            double height = 0.02
            double3 xformOp:translate = (0, 0, -0.01)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            rel material:binding = </RockerBogie/Looks/Lens_Mat>
            bool physics:collisionEnabled = false
        }
    }

    # ── Left rocker ─────────────────────────────────────────────────────────
    def Xform "RockerL" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 50.0
        float3 physics:diagonalInertia = (30.0, 30.0, 3.0)
        double3 xformOp:translate = (-0.9, -0.2, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Rocker main forward-down link (pivots down/forward to front wheel)
        # Length: 1.265m, Midpoint: (0.0, -0.2, -0.6), Rotated: -18.43 deg about X
        def Cylinder "FrontLink"
        {
            uniform token axis = "Z"
            double radius = 0.06
            double height = 1.265
            double3 xformOp:translate = (0.0, -0.2, -0.6)
            double3 xformOp:rotateXYZ = (-18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.35, 0.35, 0.38)]
            bool physics:collisionEnabled = false
        }

        # Rocker rear-down link (pivots down/backward to bogie hinge)
        # Length: 0.632m, Midpoint: (0.0, -0.1, 0.3), Rotated: 18.43 deg about X
        def Cylinder "RearLink"
        {
            uniform token axis = "Z"
            double radius = 0.06
            double height = 0.632
            double3 xformOp:translate = (0.0, -0.1, 0.3)
            double3 xformOp:rotateXYZ = (18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.35, 0.35, 0.38)]
            bool physics:collisionEnabled = false
        }

        # Outward X-axis axle to front wheel
        def Cylinder "Axle"
        {
            uniform token axis = "X"
            double radius = 0.04
            double height = 0.25
            double3 xformOp:translate = (-0.125, -0.4, -1.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        # Rocker joint cover housing
        def Cylinder "JointCover"
        {
            uniform token axis = "X"
            double radius = 0.12
            double height = 0.12
            double3 xformOp:translate = (0.0, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.85, 0.7, 0.2)]
            bool physics:collisionEnabled = false
        }

        # Simplified box collider for the rocker arm (clears the bogie space).
        # `visibility = "invisible"` — collision-only: the loader would otherwise
        # render this as a white bar (no displayColor → Color::WHITE fallback).
        def Cube "Collider" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.12, 0.12, 1.2)
            double3 xformOp:translate = (0.0, -0.2, -0.6)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
            token visibility = "invisible"
            bool physics:collisionEnabled = true
        }

        # Front Left Wheel
        def Cylinder "Wheel_FL" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (-0.25, -0.4, -1.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            # --- WHEEL DYNAMICS CONFIGURATION ---
            int lunco:wheel:index = 0
            float physxVehicleWheel:radius = 0.4
        }
    }

    # ── Right rocker ────────────────────────────────────────────────────────
    def Xform "RockerR" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 50.0
        float3 physics:diagonalInertia = (30.0, 30.0, 3.0)
        double3 xformOp:translate = (0.9, -0.2, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cylinder "FrontLink"
        {
            uniform token axis = "Z"
            double radius = 0.06
            double height = 1.265
            double3 xformOp:translate = (0.0, -0.2, -0.6)
            double3 xformOp:rotateXYZ = (-18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.35, 0.35, 0.38)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "RearLink"
        {
            uniform token axis = "Z"
            double radius = 0.06
            double height = 0.632
            double3 xformOp:translate = (0.0, -0.1, 0.3)
            double3 xformOp:rotateXYZ = (18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.35, 0.35, 0.38)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "Axle"
        {
            uniform token axis = "X"
            double radius = 0.04
            double height = 0.25
            double3 xformOp:translate = (0.125, -0.4, -1.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "JointCover"
        {
            uniform token axis = "X"
            double radius = 0.12
            double height = 0.12
            double3 xformOp:translate = (0.0, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.85, 0.7, 0.2)]
            bool physics:collisionEnabled = false
        }

        # Simplified box collider for the rocker arm (clears the bogie space).
        # `visibility = "invisible"` — collision-only: the loader would otherwise
        # render this as a white bar (no displayColor → Color::WHITE fallback).
        def Cube "Collider" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.12, 0.12, 1.2)
            double3 xformOp:translate = (0.0, -0.2, -0.6)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
            token visibility = "invisible"
            bool physics:collisionEnabled = true
        }

        # Front Right Wheel
        def Cylinder "Wheel_FR" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (0.25, -0.4, -1.2)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 1
            float physxVehicleWheel:radius = 0.4
        }
    }

    # ── Left bogie ──────────────────────────────────────────────────────────
    def Xform "BogieL" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 30.0
        float3 physics:diagonalInertia = (15.0, 15.0, 1.5)
        double3 xformOp:translate = (-0.9, -0.4, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Bogie front-down link (goes down/forward to middle wheel)
        # Length: 0.447m, Midpoint: (0.0, -0.1, -0.2), Rotated: -26.57 deg about X
        def Cylinder "FrontLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.447
            double3 xformOp:translate = (0.0, -0.1, -0.2)
            double3 xformOp:rotateXYZ = (-26.57, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
            bool physics:collisionEnabled = false
        }

        # Bogie rear-down link (goes down/backward to rear wheel)
        # Length: 0.632m, Midpoint: (0.0, -0.1, 0.3), Rotated: 18.43 deg about X
        def Cylinder "RearLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.632
            double3 xformOp:translate = (0.0, -0.1, 0.3)
            double3 xformOp:rotateXYZ = (18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
            bool physics:collisionEnabled = false
        }

        # Axle to middle wheel
        def Cylinder "MiddleAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (-0.125, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        # Axle to rear wheel
        def Cylinder "RearAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (-0.125, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        # Joint cover housing
        def Cylinder "JointCover"
        {
            uniform token axis = "X"
            double radius = 0.1
            double height = 0.1
            double3 xformOp:translate = (0.0, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.85, 0.7, 0.2)]
            bool physics:collisionEnabled = false
        }

        # Simplified box collider (collision-only, hidden — see RockerL/Collider).
        def Cube "Collider" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.1, 0.1, 1.2)
            double3 xformOp:translate = (0.0, -0.1, 0.1)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
            token visibility = "invisible"
            bool physics:collisionEnabled = true
        }

        # Middle Left Wheel
        def Cylinder "Wheel_ML" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (-0.25, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 2
            float physxVehicleWheel:radius = 0.4
        }

        # Rear Left Wheel
        def Cylinder "Wheel_RL" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (-0.25, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 4
            float physxVehicleWheel:radius = 0.4
        }
    }

    # ── Right bogie ─────────────────────────────────────────────────────────
    def Xform "BogieR" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float physics:mass = 30.0
        float3 physics:diagonalInertia = (15.0, 15.0, 1.5)
        double3 xformOp:translate = (0.9, -0.4, 0.6)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cylinder "FrontLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.447
            double3 xformOp:translate = (0.0, -0.1, -0.2)
            double3 xformOp:rotateXYZ = (-26.57, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "RearLink"
        {
            uniform token axis = "Z"
            double radius = 0.05
            double height = 0.632
            double3 xformOp:translate = (0.0, -0.1, 0.3)
            double3 xformOp:rotateXYZ = (18.43, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
            color3f[] primvars:displayColor = [(0.45, 0.45, 0.48)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "MiddleAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (0.125, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "RearAxle"
        {
            uniform token axis = "X"
            double radius = 0.035
            double height = 0.25
            double3 xformOp:translate = (0.125, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.6, 0.6, 0.6)]
            bool physics:collisionEnabled = false
        }

        def Cylinder "JointCover"
        {
            uniform token axis = "X"
            double radius = 0.1
            double height = 0.1
            double3 xformOp:translate = (0.0, 0.0, 0.0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.85, 0.7, 0.2)]
            bool physics:collisionEnabled = false
        }

        # Simplified box collider (collision-only, hidden — see RockerL/Collider).
        def Cube "Collider" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1.0
            double3 xformOp:scale = (0.1, 0.1, 1.2)
            double3 xformOp:translate = (0.0, -0.1, 0.1)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
            token visibility = "invisible"
            bool physics:collisionEnabled = true
        }

        # Middle Right Wheel
        def Cylinder "Wheel_MR" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (0.25, -0.2, -0.4)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 3
            float physxVehicleWheel:radius = 0.4
        }

        # Rear Right Wheel
        def Cylinder "Wheel_RR" (
            prepend references = [
                @lunco://components/mobility/wheel.usda@</Wheel>,
                @lunco://components/mobility/suspensions/rocker.usda@</Suspension>,
            ]
        )
        {
            uniform token axis = "X"
            double radius = 0.4
            double height = 0.3
            double3 xformOp:translate = (0.25, -0.2, 0.6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            color3f[] primvars:displayColor = [(0.15, 0.15, 0.15)]

            int lunco:wheel:index = 5
            float physxVehicleWheel:radius = 0.4
        }
    }

    # All joints below DELIBERATELY omit `physics:localPos0`/`localPos1`: each body's
    # placement is already its `xformOp:translate`, and the avian joint reader DERIVES
    # the anchor from the composed world poses (body1's origin in body0's rotation
    # frame; anchor on body1 = origin). This works for the sibling rocker↔bogie hinges
    # and the scaled hierarchy, so no anchor is typed — or left to drift — twice.
    # Author a `localPos0` on a joint to override the derivation.
    #
    # ── Lateral-axis revolute hinges (chassis ↔ rocker) ─────────────────────
    # HingeL/R: chassis <-> rocker joints.
    # NASA MER/MSL use mechanical stops limiting rocker travel to +/-30 to +/-45 degrees.
    # We use +/-30 degrees to keep the chassis level and prevent differential lockup.
    def PhysicsRevoluteJoint "HingeL" (
        doc = "Chassis-to-rocker hinge. Limited to +/-30 deg to match NASA mechanical stops, preventing excessive chassis roll and differential lockup."
    )
    {
        rel physics:body0 = </RockerBogie>
        rel physics:body1 = </RockerBogie/RockerL>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -30
        float physics:upperLimit = 30
    }
    def PhysicsRevoluteJoint "HingeR" (
        doc = "Chassis-to-rocker hinge. Limited to +/-30 deg to match NASA mechanical stops, preventing excessive chassis roll and differential lockup."
    )
    {
        rel physics:body0 = </RockerBogie>
        rel physics:body1 = </RockerBogie/RockerR>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -30
        float physics:upperLimit = 30
    }

    # ── Differential coupling (rocker-bogie holonomic constraint) ───────────
    # The standard PhysX gear joint over the two chassis↔rocker hinges: it softly
    # couples θ_left + θ_right → restSum (the drive's targetPosition), so the chassis
    # pitch tracks the rocker average instead of flopping on a free pitch DOF. A rigid
    # gear would fight the terrain and chatter, so the compliance is the joint's own
    # angular PhysicsDriveAPI (a strong spring-damper), not an ideal constraint.
    #   stiffness — how strongly the rockers mirror each other (default 15000)
    #   damping   — kills differential oscillation (default 1500)
    #   targetPosition — symmetric rest sum (0 rad)
    def PhysxPhysicsGearJoint "Differential" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physxGearJoint:hinge0 = </RockerBogie/HingeL>
        rel physxGearJoint:hinge1 = </RockerBogie/HingeR>
        float physxGearJoint:gearRatio = -1.0
        float drive:angular:physics:targetPosition = 0.0
        float drive:angular:physics:stiffness = 15000.0
        float drive:angular:physics:damping = 1500.0
    }

    # ── Lateral-axis revolute hinges (rocker ↔ bogie) ───────────────────────
    # BogieHingeL/R: rocker <-> bogie joints.
    # NASA rovers limit bogie rotation to +/-20 to +/-30 degrees to prevent the
    # middle/rear wheels from colliding with the rocker frame or chassis belly.
    # We use +/-20 degrees as a safe operating envelope.
    def PhysicsRevoluteJoint "BogieHingeL" (
        doc = "Rocker-to-bogie hinge. Limited to +/-20 deg to match NASA stops, preventing middle/rear wheels from colliding with the rocker frame."
    )
    {
        rel physics:body0 = </RockerBogie/RockerL>
        rel physics:body1 = </RockerBogie/BogieL>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -20
        float physics:upperLimit = 20
    }
    def PhysicsRevoluteJoint "BogieHingeR" (
        doc = "Rocker-to-bogie hinge. Limited to +/-20 deg to match NASA stops, preventing middle/rear wheels from colliding with the rocker frame."
    )
    {
        rel physics:body0 = </RockerBogie/RockerR>
        rel physics:body1 = </RockerBogie/BogieR>
        uniform token physics:axis = "X"
        float physics:lowerLimit = -20
        float physics:upperLimit = 20
    }

    # ── Wheel revolute joints (rocker/bogie ↔ wheel) ────────────────────────
    # These declare the joint-driven motorized properties. The parser auto-spawns
    # them using wheel coordinates, but targets are declared here for G4 recognition.
    def PhysicsRevoluteJoint "Wheel_FL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/RockerL>
        rel physics:body1 = </RockerBogie/RockerL/Wheel_FL>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_FR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/RockerR>
        rel physics:body1 = </RockerBogie/RockerR/Wheel_FR>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_ML_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieL>
        rel physics:body1 = </RockerBogie/BogieL/Wheel_ML>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_MR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieR>
        rel physics:body1 = </RockerBogie/BogieR/Wheel_MR>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_RL_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieL>
        rel physics:body1 = </RockerBogie/BogieL/Wheel_RL>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }

    def PhysicsRevoluteJoint "Wheel_RR_Hinge" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physics:body0 = </RockerBogie/BogieR>
        rel physics:body1 = </RockerBogie/BogieR/Wheel_RR>
        uniform token physics:axis = "X"
        float drive:angular:physics:maxForce = 12000.0
        uniform token drive:angular:physics:type = "force"
    }
}
