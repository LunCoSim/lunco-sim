#usda 1.0
(
    defaultPrim = "Rucheyok"
)

def Xform "Rucheyok" (
    prepend apiSchemas = ["PhysxVehicleContextAPI"]
)
{
    def Cube "Chassis" (
        prepend apiSchemas = ["PhysxVehicleDriveSkidAPI"]
    )
    {
        # --- Visuals ---
        double3 xformOp:scale = (15.0, 4.0, 20.0)
        double3 xformOp:translate = (0, 2.0, 0)
        color3f primvars:displayColor = (0.2, 0.5, 0.8)

        # --- Basic Physics (Avian) ---
        bool physics:rigidBodyEnabled = true
        float physics:mass = 800.0
        bool physics:collisionEnabled = true
    }

    def "Wheel_FL" (
        prepend references = </Rucheyok/Prototypes/Wheel>
    )
    {
        double3 xformOp:translate = (-10.0, 0, 10.0)
        float3 xformOp:rotateXYZ = (90, 0, 0)
        color3f primvars:displayColor = (0.0, 1.0, 0.0)

        # --- Sim Physics (LunCo Sim Intercept) ---
        int physxVehicleWheel:index = 0
        float physxVehicleWheel:radius = 4.0
        float physxVehicleSuspension:restLength = 0.5
        float physxVehicleSuspension:springStiffness = 10000.0
        float physxVehicleSuspension:springDamping = 3000.0
    }

    def "Wheel_FR" (
        prepend references = </Rucheyok/Prototypes/Wheel>
    )
    {
        double3 xformOp:translate = (10.0, 0, 10.0)
        float3 xformOp:rotateXYZ = (90, 0, 0)
        color3f primvars:displayColor = (0.0, 1.0, 0.0)

        int physxVehicleWheel:index = 1
        float physxVehicleWheel:radius = 4.0
    }

    def "Wheel_RL" (
        prepend references = </Rucheyok/Prototypes/Wheel>
    )
    {
        double3 xformOp:translate = (-10.0, 0, -10.0)
        float3 xformOp:rotateXYZ = (90, 0, 0)
        color3f primvars:displayColor = (1.0, 0.0, 0.0)

        int physxVehicleWheel:index = 2
        float physxVehicleWheel:radius = 4.0
    }

    def "Wheel_RR" (
        prepend references = </Rucheyok/Prototypes/Wheel>
    )
    {
        double3 xformOp:translate = (10.0, 0, -10.0)
        float3 xformOp:rotateXYZ = (90, 0, 0)
        color3f primvars:displayColor = (1.0, 0.0, 0.0)

        int physxVehicleWheel:index = 3
        float physxVehicleWheel:radius = 4.0
    }

    def Scope "Prototypes" (
        active = false
    )
    {
        def Cylinder "Wheel"
        {
            double3 xformOp:scale = (4.0, 2.0, 4.0)
            color3f primvars:displayColor = (0.5, 0.5, 0.5)
        }
    }
}
