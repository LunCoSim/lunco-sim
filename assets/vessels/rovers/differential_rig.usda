#usda 1.0
(
    defaultPrim = "DiffRig"
    upAxis = "Y"
    metersPerUnit = 1
)

# G5 — ISOLATED differential test rig (not a vehicle).
#
# A heavy fixed base (3000 kg pillar resting on the ground) carries two rockers
# that swing freely in air on LATERAL-axis (X) revolutes:
#   * RockerL is FRONT-HEAVY — its pivot is at the rear end, so gravity pitches
#     it nose-down toward θ_L ≈ −90°.
#   * RockerR is BALANCED — pivot at its centre, no gravity torque, so on its own
#     it stays at θ_R ≈ 0.
#
# With NO differential, RockerR stays put while RockerL hangs. A WORKING
# differential enforcing `θ_L + θ_R → 0` must drive RockerR to mirror RockerL
# (θ_R ≈ +90°). So `HingeR.angle` is the clean signal: ~0 without the coupling,
# ~−HingeL.angle with it. No ground-contact or chassis-roll confounds.

def Xform "DiffRig" (
    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI", "LunCoCatalogAPI"]
)
{
    float physics:mass = 3000.0
    float3 physics:diagonalInertia = (4000.0, 4000.0, 4000.0)

    # Isolated G5 differential TEST FIXTURE, not a vehicle (see header): kinematic
    # base, no PhysxVehicleContextAPI, no wheels, no FlightSoftware — so it can't be
    # possessed or driven. Keep it out of the spawn palette's Rovers list, where it
    # otherwise appears as a "rover" that mysteriously won't control. The G5 tests
    # load it by path directly, unaffected by this flag.
    bool lunco:spawnable = false

    # The base is a FIXED pillar (see header) — kinematic, not free-falling dynamic.
    # This also WORKS AROUND an avian 0.6.1 solver-island crash: a *dynamic* body that
    # both rests on the ground AND is the root of a joint tree with freely-swinging
    # children (the rockers) makes avian build a contact+joint island whose
    # `head_contact` goes stale → panic in `update_narrow_phase` (islands/mod.rs:547),
    # reproduced deterministically on load. Kinematic removes the dynamic ground-contact
    # island; the rockers still swing on their revolute joints, so the differential test
    # is unaffected (and cleaner — no base wobble).
    # TODO(avian-island-crash): the real fix is upstream in avian's island bookkeeping
    # on dynamic-body ground contact; can't bump avian without bumping Bevy. Revisit if
    # avian is updated, or if another scene needs a dynamic body grounded under a joint
    # tree. See lunco-usd-avian collider construction + the G5 differential rig tests.
    bool physics:kinematicEnabled = true

    # Heavy base pillar (root rigid body). Spans y -1.5..1.5 about the root; the
    # scene places the root at y=1.5 so the base rests on the ground.
    def Cube "Base" (prepend apiSchemas = ["PhysicsCollisionAPI"])
    {
        double size = 1.0
        double3 xformOp:scale = (1.5, 3.0, 1.5)
        uniform token[] xformOpOrder = ["xformOp:scale"]
        color3f[] primvars:displayColor = [(0.6, 0.6, 0.65)]
    }

    # Front-heavy rocker: centre 0.75 m forward of its pivot (pivot at rear end).
    def Cube "RockerL" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsCollisionAPI", "PhysicsMassAPI"]
    )
    {
        double size = 1.0
        float physics:mass = 60.0
        float3 physics:diagonalInertia = (50.0, 50.0, 5.0)
        float physxRigidBody:angularDamping = 8.0
        double3 xformOp:translate = (-1.2, 1.0, 0.75)
        double3 xformOp:scale = (0.2, 0.2, 1.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.85, 0.2, 0.2)]
    }

    # Balanced rocker: pivot at its centre (no gravity torque).
    def Cube "RockerR" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsCollisionAPI", "PhysicsMassAPI"]
    )
    {
        double size = 1.0
        float physics:mass = 60.0
        float3 physics:diagonalInertia = (50.0, 50.0, 5.0)
        float physxRigidBody:angularDamping = 8.0
        double3 xformOp:translate = (1.2, 1.0, 0.0)
        double3 xformOp:scale = (0.2, 0.2, 1.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        color3f[] primvars:displayColor = [(0.2, 0.2, 0.85)]
    }

    def PhysicsRevoluteJoint "HingeL"
    {
        rel physics:body0 = </DiffRig>
        rel physics:body1 = </DiffRig/RockerL>
        uniform token physics:axis = "X"
        point3f physics:localPos0 = (-1.2, 1.0, 0.0)
        point3f physics:localPos1 = (0.0, 0.0, -0.75)
    }
    def PhysicsRevoluteJoint "HingeR"
    {
        rel physics:body0 = </DiffRig>
        rel physics:body1 = </DiffRig/RockerR>
        uniform token physics:axis = "X"
        point3f physics:localPos0 = (1.2, 1.0, 0.0)
        point3f physics:localPos1 = (0.0, 0.0, 0.0)
    }

    # Differential coupling over the two hinges (standard PhysX gear joint): softly
    # enforces θ_L + θ_R → targetPosition via the joint's own angular drive. This is
    # the signal the G5 test reads — HingeR mirrors HingeL only when this resolves.
    def PhysxPhysicsGearJoint "Differential" (
        prepend apiSchemas = ["PhysicsDriveAPI:angular"]
    )
    {
        rel physxGearJoint:hinge0 = </DiffRig/HingeL>
        rel physxGearJoint:hinge1 = </DiffRig/HingeR>
        float physxGearJoint:gearRatio = -1.0
        float drive:angular:physics:targetPosition = 0.0
        float drive:angular:physics:stiffness = 8000.0
        float drive:angular:physics:damping = 1200.0
    }
}
